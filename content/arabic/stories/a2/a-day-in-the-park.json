{
  "id": "a-day-in-the-park",
  "level": "a2",
  "title": "يَوْمٌ فِي الْحَدِيقَةِ",
  "translit": "Yawmun fī l-ḥadīqati",
  "titleTranslation_uz": "Bog'da bir kun",
  "titleTranslation_ru": "День в парке",
  "titleTranslation_en": "A Day in the Park",
  "sentences": [
    {
      "id": "s1",
      "text_translation_uz": "Mening ismim Ali.",
      "text_translation_ru": "Меня зовут Али.",
      "text_translation_en": "My name is Ali.",
      "ar_m": "اِسْمِي عَلِيٌّ.",
      "translit_m": "Ismī ʿAliyyun.",
      "ar_f": "اِسْمِي عَلِيَاءُ.",
      "translit_f": "Ismī ʿAliyāʾu.",
      "text_translation_uz_f": "Mening ismim Aliya.",
      "text_translation_ru_f": "Меня зовут Алия.",
      "text_translation_en_f": "My name is Aliya.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s1.mp3?v=a973e51452",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s1.mp3?v=e905dda826"
    },
    {
      "id": "s2",
      "text_translation_uz": "Men talabaman.",
      "text_translation_ru": "Я студент.",
      "text_translation_en": "I am a student.",
      "ar_m": "أَنَا طَالِبٌ.",
      "translit_m": "Anā ṭālibun.",
      "ar_f": "أَنَا طَالِبَةٌ.",
      "translit_f": "Anā ṭālibatun.",
      "text_translation_ru_f": "Я студентка.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s2.mp3?v=26b1539d74",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s2.mp3?v=0490594bcf"
    },
    {
      "id": "s3",
      "ar": "أَسْكُنُ فِي مَدِينَةٍ صَغِيرَةٍ.",
      "translit": "Askunu fī madīnatin ṣaghīratin.",
      "text_translation_uz": "Men kichik shaharda yashayman.",
      "text_translation_ru": "Я живу в маленьком городе.",
      "text_translation_en": "I live in a small city.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s3.mp3?v=b38033a2e2",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s3.mp3?v=0e159c7d23"
    },
    {
      "id": "s4",
      "ar": "الْيَوْمَ الْجَوُّ جَمِيلٌ.",
      "translit": "al-yawma l-jawwu jamīlun.",
      "text_translation_uz": "Bugun havo chiroyli.",
      "text_translation_ru": "Сегодня прекрасная погода.",
      "text_translation_en": "Today the weather is beautiful.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s4.mp3?v=6602c585c9",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s4.mp3?v=f83dfe65cf"
    },
    {
      "id": "s5",
      "text_translation_uz": "Men do'stim Umar bilan bog'ga boraman.",
      "text_translation_ru": "Я иду в парк с моим другом Омаром.",
      "text_translation_en": "I go to the park with my friend Omar.",
      "ar_m": "أَذْهَبُ إِلَى الْحَدِيقَةِ مَعَ صَدِيقِي عُمَرَ.",
      "translit_m": "Adhhabu ilā l-ḥadīqati maʿa ṣadīqī ʿUmara.",
      "ar_f": "أَذْهَبُ إِلَى الْحَدِيقَةِ مَعَ صَدِيقَتِي عَائِشَةَ.",
      "translit_f": "Adhhabu ilā l-ḥadīqati maʿa ṣadīqatī ʿĀʾishata.",
      "text_translation_uz_f": "Men do'stim Aysha bilan bog'ga boraman.",
      "text_translation_ru_f": "Я иду в парк с моей подругой Аишей.",
      "text_translation_en_f": "I go to the park with my friend Aisha.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s5.mp3?v=f617e0a644",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s5.mp3?v=ec654d61d5"
    },
    {
      "id": "s6",
      "ar": "نَحْنُ نَمْشِي وَنَتَحَدَّثُ.",
      "translit": "Naḥnu namshī wa-nataḥaddathu.",
      "text_translation_uz": "Biz yuramiz va suhbatlashamiz.",
      "text_translation_ru": "Мы гуляем и разговариваем.",
      "text_translation_en": "We walk and talk.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s6.mp3?v=eab8bb9731",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s6.mp3?v=875177fda5"
    },
    {
      "id": "s7",
      "ar": "فِي الْحَدِيقَةِ أَشْجَارٌ وَزُهُورٌ كَثِيرَةٌ.",
      "translit": "Fī l-ḥadīqati ashjārun wa-zuhūrun kathīratun.",
      "text_translation_uz": "Bog'da ko'plab daraxtlar va gullar bor.",
      "text_translation_ru": "В парке много деревьев и цветов.",
      "text_translation_en": "In the park there are many trees and flowers.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s7.mp3?v=4262029ebf",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s7.mp3?v=dab24b1007"
    },
    {
      "id": "s8",
      "ar": "نَجْلِسُ عَلَى مَقْعَدٍ.",
      "translit": "Najlisu ʿalā maqʿadin.",
      "text_translation_uz": "Biz skameykaga o'tiramiz.",
      "text_translation_ru": "Мы садимся на скамейку.",
      "text_translation_en": "We sit on a bench.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s8.mp3?v=4c471bbcc0",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s8.mp3?v=157686553e"
    },
    {
      "id": "s9",
      "text_translation_uz": "Umar suv ichadi, men esa olma yeyman.",
      "text_translation_ru": "Омар пьёт воду, а я ем яблоко.",
      "text_translation_en": "Omar drinks water, and I eat an apple.",
      "ar_m": "عُمَرُ يَشْرَبُ الْمَاءَ، وَأَنَا آكُلُ تُفَّاحَةً.",
      "translit_m": "ʿUmaru yashrabu l-māʾa, wa-anā ākulu tuffāḥatan.",
      "ar_f": "عَائِشَةُ تَشْرَبُ الْمَاءَ، وَأَنَا آكُلُ تُفَّاحَةً.",
      "translit_f": "ʿĀʾishatu tashrabu l-māʾa, wa-anā ākulu tuffāḥatan.",
      "text_translation_uz_f": "Aysha suv ichadi, men esa olma yeyman.",
      "text_translation_ru_f": "Аиша пьёт воду, а я ем яблоко.",
      "text_translation_en_f": "Aisha drinks water, and I eat an apple.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s9.mp3?v=4656cf93c3",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s9.mp3?v=cb65c55914"
    },
    {
      "id": "s10",
      "ar": "نَرَى أَطْفَالًا يَلْعَبُونَ بِالْكُرَةِ.",
      "translit": "Narā aṭfālan yalʿabūna bi-l-kurati.",
      "text_translation_uz": "Biz to'p bilan o'ynayotgan bolalarni ko'ramiz.",
      "text_translation_ru": "Мы видим детей, играющих с мячом.",
      "text_translation_en": "We see children playing with the ball.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s10.mp3?v=a0530d381b",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s10.mp3?v=dc6ce5990c"
    },
    {
      "id": "s11",
      "ar": "هُمْ سُعَدَاءُ.",
      "translit": "Hum suʿadāʾu.",
      "text_translation_uz": "Ular xursand.",
      "text_translation_ru": "Они счастливы.",
      "text_translation_en": "They are happy.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s11.mp3?v=1a89993d17",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s11.mp3?v=7bfbd0d761"
    },
    {
      "id": "s12",
      "ar": "بَعْدَ سَاعَةٍ نَعُودُ إِلَى الْبَيْتِ.",
      "translit": "Baʿda sāʿatin naʿūdu ilā l-bayti.",
      "text_translation_uz": "Bir soatdan keyin biz uyga qaytamiz.",
      "text_translation_ru": "Через час мы возвращаемся домой.",
      "text_translation_en": "After an hour we return home.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s12.mp3?v=d9a7a4980e",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s12.mp3?v=58be2e0698"
    },
    {
      "id": "s13",
      "text_translation_uz": "Men xursandman, va kun chiroyli o'tdi.",
      "text_translation_ru": "Я счастлив, и день был прекрасным.",
      "text_translation_en": "I am happy, and the day was beautiful.",
      "ar_m": "أَنَا سَعِيدٌ، وَالْيَوْمُ كَانَ جَمِيلًا.",
      "translit_m": "Anā saʿīdun, wa-l-yawmu kāna jamīlan.",
      "ar_f": "أَنَا سَعِيدَةٌ، وَالْيَوْمُ كَانَ جَمِيلًا.",
      "translit_f": "Anā saʿīdatun, wa-l-yawmu kāna jamīlan.",
      "text_translation_ru_f": "Я счастлива, и день был прекрасным.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/omar/s13.mp3?v=7d12101b61",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/a-day-in-the-park/female/s13.mp3?v=f34779d764"
    }
  ],
