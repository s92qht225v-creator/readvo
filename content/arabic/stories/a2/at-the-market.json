{
  "id": "at-the-market",
  "level": "a2",
  "title": "فِي السُّوقِ",
  "translit": "Fī s-sūqi",
  "titleTranslation_uz": "Bozorda",
  "titleTranslation_ru": "На рынке",
  "titleTranslation_en": "At the Market",
  "sentences": [
    {
      "id": "s1",
      "ar_m": "اِسْمِي مُحَمَّدٌ.",
      "translit_m": "Ismī Muḥammadun.",
      "ar_f": "اِسْمِي فَاطِمَةُ.",
      "translit_f": "Ismī Fāṭimatu.",
      "text_translation_uz": "Mening ismim Muhammad.",
      "text_translation_ru": "Меня зовут Мухаммад.",
      "text_translation_en": "My name is Muhammad.",
      "text_translation_uz_f": "Mening ismim Fotima.",
      "text_translation_ru_f": "Меня зовут Фатима.",
      "text_translation_en_f": "My name is Fatima.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s1.mp3?v=9a9695fe9a",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s1.mp3?v=49eb9f736c"
    },
    {
      "id": "s2",
      "ar_m": "أَنَا طَالِبٌ.",
      "translit_m": "Anā ṭālibun.",
      "ar_f": "أَنَا طَالِبَةٌ.",
      "translit_f": "Anā ṭālibatun.",
      "text_translation_uz": "Men talabaman.",
      "text_translation_ru": "Я студент.",
      "text_translation_en": "I am a student.",
      "text_translation_ru_f": "Я студентка.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s2.mp3?v=353ea3039f",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s2.mp3?v=8acdae7d4b"
    },
    {
      "id": "s3",
      "ar_m": "الْيَوْمَ أَذْهَبُ إِلَى السُّوقِ مَعَ أَبِي.",
      "translit_m": "al-yawma adhhabu ilā s-sūqi maʿa abī.",
      "ar_f": "الْيَوْمَ أَذْهَبُ إِلَى السُّوقِ مَعَ أُمِّي.",
      "translit_f": "al-yawma adhhabu ilā s-sūqi maʿa ummī.",
      "text_translation_uz": "Bugun otam bilan bozorga boraman.",
      "text_translation_ru": "Сегодня я иду на рынок с отцом.",
      "text_translation_en": "Today I go to the market with my father.",
      "text_translation_uz_f": "Bugun onam bilan bozorga boraman.",
      "text_translation_ru_f": "Сегодня я иду на рынок с мамой.",
      "text_translation_en_f": "Today I go to the market with my mother.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s3.mp3?v=0313505dc3",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s3.mp3?v=010aafefc7"
    },
    {
      "id": "s4",
      "ar": "السُّوقُ كَبِيرٌ وَنَظِيفٌ.",
      "translit": "as-sūqu kabīrun wa-naẓīfun.",
      "text_translation_uz": "Bozor katta va toza.",
      "text_translation_ru": "Рынок большой и чистый.",
      "text_translation_en": "The market is big and clean.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s4.mp3?v=5f98308c6d",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s4.mp3?v=381131ab85"
    },
    {
      "id": "s5",
      "ar": "نَرَى فَوَاكِهَ وَخُضْرَوَاتٍ كَثِيرَةً.",
      "translit": "narā fawākiha wa-khuḍrawātin kathīratan.",
      "text_translation_uz": "Biz ko'plab meva va sabzavotlarni ko'ramiz.",
      "text_translation_ru": "Мы видим много фруктов и овощей.",
      "text_translation_en": "We see many fruits and vegetables.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s5.mp3?v=92d1c486a2",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s5.mp3?v=c08f14fd9c"
    },
    {
      "id": "s6",
      "ar_m": "أَبِي يَشْتَرِي تُفَّاحًا وَمَوْزًا وَخُبْزًا.",
      "translit_m": "abī yashtarī tuffāḥan wa-mawzan wa-khubzan.",
      "ar_f": "أُمِّي تَشْتَرِي تُفَّاحًا وَمَوْزًا وَخُبْزًا.",
      "translit_f": "ummī tashtarī tuffāḥan wa-mawzan wa-khubzan.",
      "text_translation_uz": "Otam olma, banan va non sotib oladi.",
      "text_translation_ru": "Мой отец покупает яблоки, бананы и хлеб.",
      "text_translation_en": "My father buys apples, bananas, and bread.",
      "text_translation_uz_f": "Onam olma, banan va non sotib oladi.",
      "text_translation_ru_f": "Моя мама покупает яблоки, бананы и хлеб.",
      "text_translation_en_f": "My mother buys apples, bananas, and bread.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s6.mp3?v=b990a2ab1d",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s6.mp3?v=ef02d18ef7"
    },
    {
      "id": "s7",
      "ar": "أَنَا أَشْرَبُ الْمَاءَ.",
      "translit": "anā ashrabu l-māʾa.",
      "text_translation_uz": "Men suv ichaman.",
      "text_translation_ru": "Я пью воду.",
      "text_translation_en": "I drink water.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s7.mp3?v=fe31cc84ab",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s7.mp3?v=46255ff511"
    },
    {
      "id": "s8",
      "ar": "بَعْدَ ذَلِكَ نَعُودُ إِلَى الْبَيْتِ.",
      "translit": "baʿda dhālika naʿūdu ilā l-bayti.",
      "text_translation_uz": "Shundan so'ng biz uyga qaytamiz.",
      "text_translation_ru": "После этого мы возвращаемся домой.",
      "text_translation_en": "After that we return home.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s8.mp3?v=77eb35e1b4",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s8.mp3?v=0ff826c1a4"
    },
    {
      "id": "s9",
      "ar_m": "أَنَا سَعِيدٌ، وَأَبِي سَعِيدٌ أَيْضًا.",
      "translit_m": "anā saʿīdun, wa-abī saʿīdun ayḍan.",
      "ar_f": "أَنَا سَعِيدَةٌ، وَأُمِّي سَعِيدَةٌ أَيْضًا.",
      "translit_f": "anā saʿīdatun, wa-ummī saʿīdatun ayḍan.",
      "text_translation_uz": "Men xursandman, otam ham xursand.",
      "text_translation_ru": "Я счастлив, и мой отец тоже счастлив.",
      "text_translation_en": "I am happy, and my father is happy too.",
      "text_translation_uz_f": "Men xursandman, onam ham xursand.",
      "text_translation_ru_f": "Я счастлива, и моя мама тоже счастлива.",
      "text_translation_en_f": "I am happy, and my mother is happy too.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/omar/s9.mp3?v=9ae6cec8bc",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-market/female/s9.mp3?v=2825a4192d"
    }
  ],
