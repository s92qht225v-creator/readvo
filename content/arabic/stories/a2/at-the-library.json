{
  "id": "at-the-library",
  "level": "a2",
  "title": "فِي الْمَكْتَبَةِ",
  "translit": "Fī l-maktabati",
  "titleTranslation_uz": "Kutubxonada",
  "titleTranslation_ru": "В библиотеке",
  "titleTranslation_en": "At the Library",
  "sentences": [
    {
      "id": "s1",
      "ar_m": "الْيَوْمَ أَذْهَبُ إِلَى الْمَكْتَبَةِ مَعَ صَدِيقِي أَحْمَدَ.",
      "translit_m": "al-yawma adhhabu ilā l-maktabati maʿa ṣadīqī Aḥmada.",
      "ar_f": "الْيَوْمَ أَذْهَبُ إِلَى الْمَكْتَبَةِ مَعَ صَدِيقَتِي فَاطِمَةَ.",
      "translit_f": "al-yawma adhhabu ilā l-maktabati maʿa ṣadīqatī Fāṭimata.",
      "text_translation_uz": "Bugun do'stim Ahmad bilan kutubxonaga boraman.",
      "text_translation_ru": "Сегодня я иду в библиотеку с моим другом Ахмадом.",
      "text_translation_en": "Today I go to the library with my friend Ahmad.",
      "text_translation_uz_f": "Bugun dugonam Fotima bilan kutubxonaga boraman.",
      "text_translation_ru_f": "Сегодня я иду в библиотеку с моей подругой Фатимой.",
      "text_translation_en_f": "Today I go to the library with my friend Fatima.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s1.mp3?v=05b2559669",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s1.mp3?v=9ffe63937d"
    },
    {
      "id": "s2",
      "ar": "الْمَكْتَبَةُ هَادِئَةٌ وَكَبِيرَةٌ.",
      "translit": "al-maktabatu hādiʾatun wa-kabīratun.",
      "text_translation_uz": "Kutubxona tinch va katta.",
      "text_translation_ru": "Библиотека тихая и большая.",
      "text_translation_en": "The library is quiet and big.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s2.mp3?v=663e161831",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s2.mp3?v=0f866d8f30"
    },
    {
      "id": "s3",
      "ar": "نَرَى كُتُبًا كَثِيرَةً.",
      "translit": "narā kutuban kathīratan.",
      "text_translation_uz": "Biz ko'plab kitoblarni ko'ramiz.",
      "text_translation_ru": "Мы видим много книг.",
      "text_translation_en": "We see many books.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s3.mp3?v=54cac33650",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s3.mp3?v=90c6529486"
    },
    {
      "id": "s4",
      "ar_m": "أَحْمَدُ يَقْرَأُ كِتَابًا عَنِ الْحَيَوَانَاتِ، وَأَنَا أَقْرَأُ كِتَابًا عَنِ السَّيَّارَاتِ.",
      "translit_m": "Aḥmadu yaqraʾu kitāban ʿani l-ḥayawānāti, wa-anā aqraʾu kitāban ʿani s-sayyārāti.",
      "ar_f": "فَاطِمَةُ تَقْرَأُ كِتَابًا عَنِ الْحَيَوَانَاتِ، وَأَنَا أَقْرَأُ كِتَابًا عَنِ السَّيَّارَاتِ.",
      "translit_f": "Fāṭimatu taqraʾu kitāban ʿani l-ḥayawānāti, wa-anā aqraʾu kitāban ʿani s-sayyārāti.",
      "text_translation_uz": "Ahmad hayvonlar haqidagi kitobni o'qiydi, men esa mashinalar haqidagi kitobni o'qiyman.",
      "text_translation_ru": "Ахмад читает книгу о животных, а я читаю книгу о машинах.",
      "text_translation_en": "Ahmad reads a book about animals, and I read a book about cars.",
      "text_translation_uz_f": "Fotima hayvonlar haqidagi kitobni o'qiydi, men esa mashinalar haqidagi kitobni o'qiyman.",
      "text_translation_ru_f": "Фатима читает книгу о животных, а я читаю книгу о машинах.",
      "text_translation_en_f": "Fatima reads a book about animals, and I read a book about cars.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s4.mp3?v=6870143a61",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s4.mp3?v=bee2c7bfd3"
    },
    {
      "id": "s5",
      "ar": "بَعْدَ سَاعَةٍ أَسْتَعِيرُ كِتَابًا، ثُمَّ نَخْرُجُ مِنَ الْمَكْتَبَةِ وَنَعُودُ إِلَى الْبَيْتِ.",
      "translit": "baʿda sāʿatin astaʿīru kitāban, thumma nakhruju mina l-maktabati wa-naʿūdu ilā l-bayti.",
      "text_translation_uz": "Bir soatdan keyin kitob ijaraga olaman, so'ng kutubxonadan chiqib uyga qaytamiz.",
      "text_translation_ru": "Через час я беру книгу, затем мы выходим из библиотеки и возвращаемся домой.",
      "text_translation_en": "After an hour I borrow a book, then we leave the library and return home.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s5.mp3?v=eda8e52132",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s5.mp3?v=4b51b33aa1"
    },
    {
      "id": "s6",
      "ar": "فِي الْمَسَاءِ أَكْتُبُ وَاجِبِي.",
      "translit": "fī l-masāʾi aktubu wājibī.",
      "text_translation_uz": "Kechqurun uy vazifamni bajaraman.",
      "text_translation_ru": "Вечером я делаю домашнее задание.",
      "text_translation_en": "In the evening I do my homework.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/omar/s6.mp3?v=45b947ee81",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/at-the-library/female/s6.mp3?v=027ecf1073"
    }
  ],
