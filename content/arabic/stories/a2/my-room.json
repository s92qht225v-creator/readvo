{
  "id": "my-room",
  "level": "a2",
  "title": "غُرْفَتِي",
  "translit": "Ghurfatī",
  "titleTranslation_uz": "Mening xonam",
  "titleTranslation_ru": "Моя комната",
  "titleTranslation_en": "My Room",
  "sentences": [
    {
      "id": "s1",
      "ar": "هَذِهِ غُرْفَتِي.",
      "translit": "Hādhihi ghurfatī.",
      "text_translation_uz": "Bu mening xonam.",
      "text_translation_ru": "Это моя комната.",
      "text_translation_en": "This is my room.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s1.mp3?v=87f8856b16",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s1.mp3?v=ecebe58e0e"
    },
    {
      "id": "s2",
      "ar": "هِيَ صَغِيرَةٌ لَكِنَّهَا جَمِيلَةٌ.",
      "translit": "Hiya ṣaghīratun lākinnahā jamīlatun.",
      "text_translation_uz": "U kichkina, lekin chiroyli.",
      "text_translation_ru": "Она маленькая, но красивая.",
      "text_translation_en": "It is small, but it is beautiful.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s2.mp3?v=1443a6ce52",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s2.mp3?v=b4fd57aa81"
    },
    {
      "id": "s3",
      "ar": "فِي الغُرْفَةِ سَرِيرٌ كَبِيرٌ.",
      "translit": "Fī l-ghurfati sarīrun kabīrun.",
      "text_translation_uz": "Xonada katta karavot bor.",
      "text_translation_ru": "В комнате большая кровать.",
      "text_translation_en": "In the room there is a big bed.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s3.mp3?v=7034c59aa5",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s3.mp3?v=9ff7931f44"
    },
    {
      "id": "s4",
      "ar": "عَلَى السَّرِيرِ وِسَادَةٌ وَلِحَافٌ.",
      "translit": "ʿalā s-sarīri wisādatun wa-liḥāfun.",
      "text_translation_uz": "Karavotda yostiq va ko'rpa bor.",
      "text_translation_ru": "На кровати подушка и одеяло.",
      "text_translation_en": "On the bed there is a pillow and a blanket.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s4.mp3?v=fabd630f33",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s4.mp3?v=7985c0d7c5"
    },
    {
      "id": "s5",
      "ar": "الوِسَادَةُ نَاعِمَةٌ وَاللِّحَافُ دَافِئٌ.",
      "translit": "al-wisādatu nāʿimatun wa-l-liḥāfu dāfiʾun.",
      "text_translation_uz": "Yostiq yumshoq, ko'rpa esa issiq.",
      "text_translation_ru": "Подушка мягкая, а одеяло тёплое.",
      "text_translation_en": "The pillow is soft and the blanket is warm.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s5.mp3?v=1955a02aef",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s5.mp3?v=c31767f5f0"
    },
    {
      "id": "s6",
      "ar": "بِجَانِبِ السَّرِيرِ مَكْتَبٌ.",
      "translit": "bijānibi s-sarīri maktabun.",
      "text_translation_uz": "Karavot yonida stol bor.",
      "text_translation_ru": "Рядом с кроватью стол.",
      "text_translation_en": "Next to the bed there is a desk.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s6.mp3?v=141e23ab82",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s6.mp3?v=7591221999"
    },
    {
      "id": "s7",
      "ar": "المَكْتَبُ خَشَبِيٌّ وَصَغِيرٌ.",
      "translit": "al-maktabu khashabiyyun wa-ṣaghīrun.",
      "text_translation_uz": "Stol yog'ochdan va kichkina.",
      "text_translation_ru": "Стол деревянный и маленький.",
      "text_translation_en": "The desk is wooden and small.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s7.mp3?v=85f23e8f6e",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s7.mp3?v=76b4f9ffd3"
    },
    {
      "id": "s8",
      "ar": "عَلَى المَكْتَبِ كِتَابٌ وَقَلَمٌ وَدَفْتَرٌ.",
      "translit": "ʿalā l-maktabi kitābun wa-qalamun wa-daftarun.",
      "text_translation_uz": "Stolda kitob, ruchka va daftar bor.",
      "text_translation_ru": "На столе книга, ручка и тетрадь.",
      "text_translation_en": "On the desk there is a book, a pen and a notebook.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s8.mp3?v=6c68238817",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s8.mp3?v=7f52c896a9"
    },
    {
      "id": "s9",
      "ar": "الكِتَابُ جَدِيدٌ.",
      "translit": "al-kitābu jadīdun.",
      "text_translation_uz": "Kitob yangi.",
      "text_translation_ru": "Книга новая.",
      "text_translation_en": "The book is new.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s9.mp3?v=160310d47a",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s9.mp3?v=ddf4fffa30"
    },
    {
      "id": "s10",
      "ar": "القَلَمُ أَزْرَقُ.",
      "translit": "al-qalamu azraqu.",
      "text_translation_uz": "Ruchka ko'k.",
      "text_translation_ru": "Ручка синяя.",
      "text_translation_en": "The pen is blue.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s10.mp3?v=992e7d2d3b",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s10.mp3?v=26d75bf714"
    },
    {
      "id": "s11",
      "ar": "الدَّفْتَرُ أَبْيَضُ.",
      "translit": "ad-daftaru abyaḍu.",
      "text_translation_uz": "Daftar oq.",
      "text_translation_ru": "Тетрадь белая.",
      "text_translation_en": "The notebook is white.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s11.mp3?v=b0f6232ca7",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s11.mp3?v=a9277c8eba"
    },
    {
      "id": "s12",
      "ar": "أَكْتُبُ فِي الدَّفْتَرِ.",
      "translit": "aktubu fī d-daftari.",
      "text_translation_uz": "Men daftarga yozaman.",
      "text_translation_ru": "Я пишу в тетради.",
      "text_translation_en": "I write in the notebook.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s12.mp3?v=c1f02caf57",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s12.mp3?v=0bcbf23712"
    },
    {
      "id": "s13",
      "ar": "وَأَقْرَأُ الكِتَابَ.",
      "translit": "wa-aqraʾu l-kitāba.",
      "text_translation_uz": "Va kitobni o'qiyman.",
      "text_translation_ru": "И читаю книгу.",
      "text_translation_en": "And I read the book.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s13.mp3?v=84496af324",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s13.mp3?v=5f6e11645f"
    },
    {
      "id": "s14",
      "ar": "تَحْتَ المَكْتَبِ كُرْسِيٌّ أَصْفَرُ.",
      "translit": "taḥta l-maktabi kursiyyun aṣfaru.",
      "text_translation_uz": "Stol ostida sariq stul bor.",
      "text_translation_ru": "Под столом жёлтый стул.",
      "text_translation_en": "Under the desk there is a yellow chair.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s14.mp3?v=8590b6669a",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s14.mp3?v=3fe76b0cd3"
    },
    {
      "id": "s15",
      "ar": "أَجْلِسُ عَلَى الكُرْسِيِّ.",
      "translit": "ajlisu ʿalā l-kursiyyi.",
      "text_translation_uz": "Men stulga o'tiraman.",
      "text_translation_ru": "Я сижу на стуле.",
      "text_translation_en": "I sit on the chair.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s15.mp3?v=53ffebdffa",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s15.mp3?v=ce1f36e546"
    },
    {
      "id": "s16",
      "ar": "فِي الغُرْفَةِ نَافِذَةٌ كَبِيرَةٌ.",
      "translit": "fī l-ghurfati nāfidhatun kabīratun.",
      "text_translation_uz": "Xonada katta deraza bor.",
      "text_translation_ru": "В комнате большое окно.",
      "text_translation_en": "In the room there is a big window.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s16.mp3?v=ae8d37db39",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s16.mp3?v=86bdb489ea"
    },
    {
      "id": "s17",
      "ar": "النَّافِذَةُ تُطِلُّ عَلَى الحَدِيقَةِ.",
      "translit": "an-nāfidhatu tuṭillu ʿalā l-ḥadīqati.",
      "text_translation_uz": "Deraza bog'ga qaraydi.",
      "text_translation_ru": "Окно выходит в сад.",
      "text_translation_en": "The window overlooks the garden.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s17.mp3?v=7d72638ce1",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s17.mp3?v=87da90f80c"
    },
    {
      "id": "s18",
      "ar": "أُحِبُّ النَّظَرَ مِنَ النَّافِذَةِ.",
      "translit": "uḥibbu n-naẓara mina n-nāfidhati.",
      "text_translation_uz": "Men derazadan qarashni yaxshi ko'raman.",
      "text_translation_ru": "Я люблю смотреть из окна.",
      "text_translation_en": "I love looking out of the window.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s18.mp3?v=0c9d39092b",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s18.mp3?v=13abb10691"
    },
    {
      "id": "s19",
      "ar": "وَعَلَى الجِدَارِ سَاعَةٌ وَصُورَةٌ.",
      "translit": "wa-ʿalā l-jidāri sāʿatun wa-ṣūratun.",
      "text_translation_uz": "Devorda soat va rasm bor.",
      "text_translation_ru": "А на стене часы и картина.",
      "text_translation_en": "And on the wall there is a clock and a picture.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s19.mp3?v=5470b71378",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s19.mp3?v=87c1e67306"
    },
    {
      "id": "s20",
      "ar": "الصُّورَةُ فَوْقَ السَّرِيرِ.",
      "translit": "aṣ-ṣūratu fawqa s-sarīri.",
      "text_translation_uz": "Rasm karavot tepasida.",
      "text_translation_ru": "Картина над кроватью.",
      "text_translation_en": "The picture is above the bed.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s20.mp3?v=072838059e",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s20.mp3?v=bbce156700"
    },
    {
      "id": "s21",
      "ar": "غُرْفَتِي لَيْسَتْ كَبِيرَةً، لَكِنَّهَا مَكَانِي المُفَضَّلُ.",
      "translit": "ghurfatī laysat kabīratan, lākinnahā makānī l-mufaḍḍalu.",
      "text_translation_uz": "Mening xonam katta emas, lekin u mening sevimli joyim.",
      "text_translation_ru": "Моя комната не большая, но это моё любимое место.",
      "text_translation_en": "My room is not big, but it is my favorite place.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s21.mp3?v=df41087bbe",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s21.mp3?v=0e2e57c133"
    },
    {
      "id": "s22",
      "ar": "أَنَا سَعِيدٌ فِيهَا.",
      "translit": "anā saʿīdun fīhā.",
      "text_translation_uz": "Men unda baxtliman.",
      "text_translation_ru": "Я счастлив в ней.",
      "text_translation_en": "I am happy in it.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/omar/s22.mp3?v=e8b7bca968",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/stories/a2/my-room/female/s22.mp3?v=e84d2df414",
      "ar_m": "أَنَا سَعِيدٌ فِيهَا.",
      "translit_m": "anā saʿīdun fīhā.",
      "ar_f": "أَنَا سَعِيدَةٌ فِيهَا.",
      "translit_f": "anā saʿīdatun fīhā.",
      "text_translation_ru_f": "Я счастлива в ней."
    }
  ],
