    {
      "id": "s1",
      "speaker": "A",
      "ar_m": "هَلْ تُحِبُّ الطَّعَامَ الْعَرَبِيَّ؟",
      "translit_m": "Hal tuḥibbu aṭ-ṭaʿāma al-ʿarabiyya?",
      "ar_f": "هَلْ تُحِبِّينَ الطَّعَامَ الْعَرَبِيَّ؟",
      "translit_f": "Hal tuḥibbīna aṭ-ṭaʿāma al-ʿarabiyya?",
      "text_translation_uz": "Arab taomini yoqtirasanmi?",
      "text_translation_ru": "Ты любишь арабскую еду?",
      "text_translation_en": "Do you like Arabic food?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/omar/s1.mp3?v=42bd24fc51",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/female/s1.mp3?v=b79bc760f3"
    },
    {
      "id": "s2",
      "speaker": "B",
      "ar_m": "نَعَمْ، أُحِبُّ الطَّعَامَ الْعَرَبِيَّ كَثِيرًا! وَأَنْتَ؟",
      "translit_m": "Naʿam, uḥibbu aṭ-ṭaʿāma al-ʿarabiyya kathīran! Wa anta?",
      "ar_f": "نَعَمْ، أُحِبُّ الطَّعَامَ الْعَرَبِيَّ كَثِيرًا! وَأَنْتِ؟",
      "translit_f": "Naʿam, uḥibbu aṭ-ṭaʿāma al-ʿarabiyya kathīran! Wa anti?",
      "text_translation_uz": "Ha, arab taomini juda yoqtiraman! Sen-chi?",
      "text_translation_ru": "Да, я очень люблю арабскую еду! А ты?",
      "text_translation_en": "Yes, I love Arabic food a lot! And you?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/omar/s2.mp3?v=3ca54ada82",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/female/s2.mp3?v=188412510e"
    },
    {
      "id": "s3",
      "speaker": "A",
      "ar_m": "أَنَا أَعْشَقُ الدَّجَاجَ وَالْأُرْزَ! هُوَ لَذِيذٌ جِدًّا.",
      "translit_m": "Anā aʿshaqu ad-dajāja wa-l-aruzza! Huwa laḏīḏun jiddan.",
      "ar_f": "أَنَا أَعْشَقُ الدَّجَاجَ وَالْأُرْزَ! هُوَ لَذِيذٌ جِدًّا.",
      "translit_f": "Anā aʿshaqu ad-dajāja wa-l-aruzza! Huwa laḏīḏun jiddan.",
      "text_translation_uz": "Men tovuq va guruchni jondan yaxshi koʻraman! U juda mazali.",
      "text_translation_ru": "Я обожаю курицу и рис! Это очень вкусно.",
      "text_translation_en": "I adore chicken and rice! It's very delicious.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/omar/s3.mp3?v=1727558f6d",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/arabic-food/female/s3.mp3?v=ec62d718d3"
    },
    {
      "id": "s4",
      "speaker": "B",
      "ar_m": "مُمْتَازٌ! صِحَّةٌ وَعَافِيَةٌ.",
      "translit_m": "Mumtāzun! Ṣiḥḥatun wa ʿāfiya.",
      "ar_f": "مُمْتَازٌ! صِحَّةٌ وَعَافِيَةٌ.",
      "translit_f": "Mumtāzun! Ṣiḥḥatun wa ʿāfiya.",
      "text_translation_uz": "Ajoyib! Yoqimli ishtaha!",
