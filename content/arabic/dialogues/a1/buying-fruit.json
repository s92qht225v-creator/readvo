  "sentences": [
    {
      "id": "s1",
      "speaker": "A",
      "ar_m": "هَلْ عِنْدَكَ فَاكِهَةٌ؟",
      "translit_m": "Hal ʿindaka fākihatun?",
      "ar_f": "هَلْ عِنْدَكِ فَاكِهَةٌ؟",
      "translit_f": "Hal ʿindaki fākihatun?",
      "text_translation_uz": "Sizda meva bormi?",
      "text_translation_ru": "У тебя есть фрукты?",
      "text_translation_en": "Do you have fruit?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s1.mp3?v=ac0fa071c9",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s1.mp3"
    },
    {
      "id": "s2",
      "speaker": "B",
      "ar_m": "نَعَمْ، عِنْدِي تَفَّاحٌ وَمَوْزٌ وَبُرْتُقَالٌ.",
      "translit_m": "Naʿam, ʿindī tuffāḥun wa mawzun wa burtuqālun.",
      "ar_f": "نَعَمْ، عِنْدِي تَفَّاحٌ وَمَوْزٌ وَبُرْتُقَالٌ.",
      "translit_f": "Naʿam, ʿindī tuffāḥun wa mawzun wa burtuqālun.",
      "text_translation_uz": "Ha, menda olma, banan va apelsin bor.",
      "text_translation_ru": "Да, у меня есть яблоки, бананы и апельсины.",
      "text_translation_en": "Yes, I have apples, bananas, and oranges.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s2.mp3?v=4d72ec6ef5",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s2.mp3"
    },
    {
      "id": "s3-s4",
      "speaker": "A",
      "ar_m": "أُرِيدُ تَفَّاحًا وَمَوْزًا. كَمْ كِيلُو التُّفَّاحِ؟",
      "translit_m": "Urīdu tuffāḥan wa mawzan. Kam kīlū t-tuffāḥi?",
      "ar_f": "أُرِيدُ تَفَّاحًا وَمَوْزًا. كَمْ كِيلُو التُّفَّاحِ؟",
      "translit_f": "Urīdu tuffāḥan wa mawzan. Kam kīlū t-tuffāḥi?",
      "text_translation_uz": "Menga olma va banan kerak. Bir kilo olma qancha turadi?",
      "text_translation_ru": "Я хочу яблоки и бананы. Сколько стоит кило яблок?",
      "text_translation_en": "I want apples and bananas. How much is a kilo of apples?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s3-s4.mp3?v=5cc97608eb",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s3-s4.mp3"
    },
    {
      "id": "s5",
      "speaker": "B",
      "ar_m": "كِيلُو التُّفَّاحِ بِخَمْسَةِ دَنَانِيرَ.",
      "translit_m": "Kīlū t-tuffāḥi bikhamsati danānīra.",
      "ar_f": "كِيلُو التُّفَّاحِ بِخَمْسَةِ دَنَانِيرَ.",
      "translit_f": "Kīlū t-tuffāḥi bikhamsati danānīra.",
      "text_translation_uz": "Bir kilo olma besh dinor.",
      "text_translation_ru": "Кило яблок — пять динаров.",
      "text_translation_en": "A kilo of apples is 5 dinars.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s5.mp3?v=7f8bded0c6",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s5.mp3"
    },
    {
      "id": "s6",
      "speaker": "A",
      "ar_m": "وَكَمْ كِيلُو الْمَوْزِ؟",
      "translit_m": "Wa kam kīlū l-mawzi?",
      "ar_f": "وَكَمْ كِيلُو الْمَوْزِ؟",
      "translit_f": "Wa kam kīlū l-mawzi?",
      "text_translation_uz": "Bir kilo banan-chi, qancha?",
      "text_translation_ru": "А сколько стоит кило бананов?",
      "text_translation_en": "And how much is a kilo of bananas?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s6.mp3?v=10a0029ae7",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s6.mp3"
    },
    {
      "id": "s7",
      "speaker": "B",
      "ar_m": "كِيلُو الْمَوْزِ بِثَلَاثَةِ دَنَانِيرَ.",
      "translit_m": "Kīlū l-mawzi bithalāthati danānīra.",
      "ar_f": "كِيلُو الْمَوْزِ بِثَلَاثَةِ دَنَانِيرَ.",
      "translit_f": "Kīlū l-mawzi bithalāthati danānīra.",
      "text_translation_uz": "Bir kilo banan uch dinor.",
      "text_translation_ru": "Кило бананов — три динара.",
      "text_translation_en": "A kilo of bananas is 3 dinars.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s7.mp3?v=1321ba843d",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s7.mp3"
    },
    {
      "id": "s8",
      "speaker": "A",
      "ar_m": "أُرِيدُ كِيلُو تَفَّاحٍ وَكِيلُو مَوْزٍ.",
      "translit_m": "Urīdu kīlū tuffāḥin wa kīlū mawzin.",
      "ar_f": "أُرِيدُ كِيلُو تَفَّاحٍ وَكِيلُو مَوْزٍ.",
      "translit_f": "Urīdu kīlū tuffāḥin wa kīlū mawzin.",
      "text_translation_uz": "Menga bir kilo olma va bir kilo banan kerak.",
      "text_translation_ru": "Я хочу один кило яблок и один кило бананов.",
      "text_translation_en": "I want one kilo of apples and one kilo of bananas.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s8.mp3?v=961bfd1d91",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s8.mp3"
    },
    {
      "id": "s9",
      "speaker": "B",
      "ar_m": "حَسَنًا. هَذَا كِيلُو تَفَّاحٍ وَهَذَا كِيلُو مَوْزٍ.",
      "translit_m": "Ḥasanan. Hādhā kīlū tuffāḥin wa hādhā kīlū mawzin.",
      "ar_f": "حَسَنًا. هَذَا كِيلُو تَفَّاحٍ وَهَذَا كِيلُو مَوْزٍ.",
      "translit_f": "Ḥasanan. Hādhā kīlū tuffāḥin wa hādhā kīlū mawzin.",
      "text_translation_uz": "Mayli. Mana bir kilo olma, mana bir kilo banan.",
      "text_translation_ru": "Хорошо. Вот кило яблок и вот кило бананов.",
      "text_translation_en": "Okay. This is one kilo of apples and this is one kilo of bananas.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s9.mp3?v=d95628182c",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s9.mp3"
    },
    {
      "id": "s10",
      "speaker": "A",
      "ar_m": "كَمِ الثَّمَنُ؟",
      "translit_m": "Kam ath-thamanu?",
      "ar_f": "كَمِ الثَّمَنُ؟",
      "translit_f": "Kam ath-thamanu?",
      "text_translation_uz": "Narxi qancha?",
      "text_translation_ru": "Сколько с меня (какова цена)?",
      "text_translation_en": "How much is the price?",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s10.mp3?v=0656476427",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s10.mp3"
    },
    {
      "id": "s11",
      "speaker": "B",
      "ar_m": "الثَّمَنُ ثَمَانِيَةُ دَنَانِيرَ.",
      "translit_m": "Ath-thamanu thamāniyatu danānīra.",
      "ar_f": "الثَّمَنُ ثَمَانِيَةُ دَنَانِيرَ.",
      "translit_f": "Ath-thamanu thamāniyatu danānīra.",
      "text_translation_uz": "Narxi sakkiz dinor.",
      "text_translation_ru": "Цена — восемь динаров.",
      "text_translation_en": "The price is 8 dinars.",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s11.mp3?v=0e2a47bddc",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s11.mp3"
    },
    {
      "id": "s12",
      "speaker": "A",
      "ar_m": "تَفَضَّلْ.",
      "translit_m": "Tafaḍḍal.",
      "ar_f": "تَفَضَّلِي.",
      "translit_f": "Tafaḍḍalī.",
      "text_translation_uz": "Mana, marhamat. (pulni berib)",
      "text_translation_ru": "Вот, пожалуйста. (отдавая деньги)",
      "text_translation_en": "Here you are. (giving the money)",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s12.mp3?v=d69c65e635",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s12.mp3"
    },
    {
      "id": "s13",
      "speaker": "B",
      "ar_m": "شُكْرًا. مَعَ السَّلَامَةِ!",
      "translit_m": "Shukran. Maʿa s-salāmah!",
      "ar_f": "شُكْرًا. مَعَ السَّلَامَةِ!",
      "translit_f": "Shukran. Maʿa s-salāmah!",
      "text_translation_uz": "Rahmat. Xayr, sogʻ boʻling!",
      "text_translation_ru": "Спасибо. До свидания!",
      "text_translation_en": "Thank you. Goodbye!",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/omar/s13.mp3?v=463bbe9070",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s13.mp3"
    },
    {
      "id": "s14",
      "speaker": "A",
      "ar_m": "مَعَ السَّلَامَةِ!",
      "translit_m": "Maʿa s-salāmah!",
      "ar_f": "مَعَ السَّلَامَةِ!",
      "translit_f": "Maʿa s-salāmah!",
      "text_translation_uz": "Xayr, sogʻ boʻling!",
      "text_translation_ru": "До свидания!",
      "text_translation_en": "Goodbye!",
      "audio_url": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/darsho/s14.mp3?v=84f85a0613",
      "audio_url_f": "https://miruwaeplbzfqmdwacsh.supabase.co/storage/v1/object/public/audio/ar/dialogues/a1/buying-fruit/female/s14.mp3"
    }
  ]
}
