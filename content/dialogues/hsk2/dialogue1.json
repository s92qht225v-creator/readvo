          "words": [
            { "i": [0, 1], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "de", "t": "egalik", "tr": "притяж.", "h": 1, "l": 2 },
            { "i": [2, 4], "p": "xuésheng", "t": "o'quvchi", "tr": "ученик", "h": 1, "l": 8 },
            { "i": [4, 5], "p": "dōu", "t": "barchasi", "tr": "все", "h": 1, "l": 3 },
            { "i": [5, 6], "p": "hěn", "t": "juda", "tr": "очень", "h": 1, "l": 3 },
            { "i": [6, 8], "p": "xǐhuan", "t": "yoqtirmoq", "tr": "нравиться", "h": 1, "l": 5 },
            { "i": [8, 9], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d1-s12",
          "text_original": "你以后想做什么工作？",
          "pinyin": "Nǐ yǐhòu xiǎng zuò shénme gōngzuò?",
          "text_translation": "Kelajakda qanday ishni qilmoqchisan?",
          "text_translation_ru": "Кем ты хочешь стать в будущем?",
          "text_translation_en": "What job do you want to do in the future?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [1, 3], "p": "yǐhòu", "t": "kelajakda", "tr": "в будущем", "h": 2 },
            { "i": [3, 4], "p": "xiǎng", "t": "xohlamoq", "tr": "хотеть", "h": 1, "l": 5 },
            { "i": [4, 5], "p": "zuò", "t": "qilmoq", "tr": "делать", "h": 1, "l": 4 },
            { "i": [5, 7], "p": "shénme", "t": "nima", "tr": "что", "h": 1, "l": 2 },
            { "i": [7, 9], "p": "gōngzuò", "t": "ish", "tr": "работа", "h": 2 }
          ]
        },
        {
          "id": "d1-s13",
          "text_original": "我想做老师，因为我喜欢帮助别人。",
          "pinyin": "Wǒ xiǎng zuò lǎoshī, yīnwèi wǒ xǐhuan bāngzhù biéren.",
          "text_translation": "Men o'qituvchi bo'lmoqchiman, chunki boshqalarga yordam berishni yoqtiraman.",
          "text_translation_ru": "Я хочу стать учителем, потому что люблю помогать другим.",
          "text_translation_en": "I want to be a teacher because I like helping others.",
