          "words": [
            { "i": [0, 1], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "jiāo", "t": "dars bermoq", "tr": "преподавать", "h": 2 },
            { "i": [2, 4], "p": "shénme", "t": "nima", "tr": "что", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d1-s10",
          "text_original": "她教中文。",
          "pinyin": "Tā jiāo Zhōngwén.",
          "text_translation": "U xitoy tilidan dars beradi.",
          "text_translation_ru": "Она преподаёт китайский.",
          "text_translation_en": "She teaches Chinese.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "jiāo", "t": "dars bermoq", "tr": "преподавать", "h": 2 },
            { "i": [2, 4], "p": "Zhōngwén", "t": "xitoy tili", "tr": "китайский язык", "h": 2 }
          ]
        },
        {
          "id": "d1-s11",
          "text_original": "她的学生都很喜欢她。",
          "pinyin": "Tā de xuésheng dōu hěn xǐhuan tā.",
          "text_translation": "Uning o'quvchilari uni juda yaxshi ko'rishadi.",
          "text_translation_ru": "Её ученики все очень любят её.",
          "text_translation_en": "Her students all like her very much.",
