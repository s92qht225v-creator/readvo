            { "i": [9, 11], "p": "xǐhuan", "t": "yoqtirmoq", "tr": "нравиться", "h": 1, "l": 5 },
            { "i": [11, 13], "p": "bāngzhù", "t": "yordam bermoq", "tr": "помогать", "h": 2 },
            { "i": [13, 15], "p": "biéren", "t": "boshqalar", "tr": "другие", "h": 2 }
          ]
        },
        {
          "id": "d1-s14",
          "text_original": "很好！",
          "pinyin": "Hěn hǎo!",
