        {
          "id": "d1-s1",
          "text_original": "你爸爸做什么工作？",
          "pinyin": "Nǐ bàba zuò shénme gōngzuò?",
          "text_translation": "Otang nima ish qiladi?",
          "text_translation_ru": "Кем работает твой папа?",
