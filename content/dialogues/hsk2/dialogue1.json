          ]
        },
        {
          "id": "d1-s2",
          "text_original": "我爸爸是医生。",
          "pinyin": "Wǒ bàba shì yīshēng.",
          "text_translation": "Otam shifokor.",
          "text_translation_ru": "Мой папа врач.",
          "text_translation_en": "My father is a doctor.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "wǒ", "t": "men", "tr": "я", "h": 1, "l": 2 },
            { "i": [1, 3], "p": "bàba", "t": "ota", "tr": "папа", "h": 1, "l": 2 },
            { "i": [3, 4], "p": "shì", "t": "bo'lmoq", "tr": "быть", "h": 1, "l": 2 },
            { "i": [4, 6], "p": "yīshēng", "t": "shifokor", "tr": "врач", "h": 2 }
          ]
        },
        {
          "id": "d1-s3",
          "text_original": "他在哪儿工作？",
          "pinyin": "Tā zài nǎr gōngzuò?",
          "text_translation": "U qayerda ishlaydi?",
          "text_translation_ru": "Где он работает?",
          "text_translation_en": "Where does he work?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "tā", "t": "u", "tr": "он", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "zài", "t": "-da", "tr": "в", "h": 1, "l": 6 },
            { "i": [2, 4], "p": "nǎr", "t": "qayer", "tr": "где", "h": 1, "l": 6 },
            { "i": [4, 6], "p": "gōngzuò", "t": "ishlamoq", "tr": "работать", "h": 2 }
          ]
        },
        {
          "id": "d1-s4",
          "text_original": "他在医院工作。",
          "pinyin": "Tā zài yīyuàn gōngzuò.",
          "text_translation": "U kasalxonada ishlaydi.",
          "text_translation_ru": "Он работает в больнице.",
          "text_translation_en": "He works at a hospital.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "tā", "t": "u", "tr": "он", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "zài", "t": "-da", "tr": "в", "h": 1, "l": 6 },
            { "i": [2, 4], "p": "yīyuàn", "t": "kasalxona", "tr": "больница", "h": 2 },
            { "i": [4, 6], "p": "gōngzuò", "t": "ishlamoq", "tr": "работать", "h": 2 }
          ]
        },
        {
          "id": "d1-s5",
          "text_original": "你妈妈呢？",
          "pinyin": "Nǐ māma ne?",
          "text_translation": "Onangchi?",
          "text_translation_ru": "А твоя мама?",
          "text_translation_en": "What about your mother?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [1, 3], "p": "māma", "t": "ona", "tr": "мама", "h": 1, "l": 2 },
            { "i": [3, 4], "p": "ne", "t": "-chi", "tr": "а", "h": 1, "l": 3 }
          ]
        },
        {
          "id": "d1-s6",
          "text_original": "她也在医院工作吗？",
          "pinyin": "Tā yě zài yīyuàn gōngzuò ma?",
          "text_translation": "U ham kasalxonada ishlaydimi?",
          "text_translation_ru": "Она тоже работает в больнице?",
          "text_translation_en": "Does she also work at a hospital?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "yě", "t": "ham", "tr": "тоже", "h": 1, "l": 3 },
            { "i": [2, 3], "p": "zài", "t": "-da", "tr": "в", "h": 1, "l": 6 },
            { "i": [3, 5], "p": "yīyuàn", "t": "kasalxona", "tr": "больница", "h": 2 },
            { "i": [5, 7], "p": "gōngzuò", "t": "ishlamoq", "tr": "работать", "h": 2 },
            { "i": [7, 8], "p": "ma", "t": "-mi (savol)", "tr": "ли (вопрос)", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d1-s7",
          "text_original": "不是。",
          "pinyin": "Bú shì.",
          "text_translation": "Yo'q.",
          "text_translation_ru": "Нет.",
          "text_translation_en": "No.",
          "speaker": "B",
          "words": [
            { "i": [0, 2], "p": "bú shì", "t": "yo'q", "tr": "нет", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d1-s8",
          "text_original": "她是老师，在学校工作。",
          "pinyin": "Tā shì lǎoshī, zài xuéxiào gōngzuò.",
          "text_translation": "U o'qituvchi, maktabda ishlaydi.",
          "text_translation_ru": "Она учительница, работает в школе.",
          "text_translation_en": "She is a teacher and works at a school.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "tā", "t": "u (ayol)", "tr": "она", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "shì", "t": "bo'lmoq", "tr": "быть", "h": 1, "l": 2 },
            { "i": [2, 4], "p": "lǎoshī", "t": "o'qituvchi", "tr": "учитель", "h": 1, "l": 1 },
            { "i": [5, 6], "p": "zài", "t": "-da", "tr": "в", "h": 1, "l": 6 },
            { "i": [6, 8], "p": "xuéxiào", "t": "maktab", "tr": "школа", "h": 1, "l": 8 },
            { "i": [8, 10], "p": "gōngzuò", "t": "ishlamoq", "tr": "работать", "h": 2 }
          ]
        },
        {
          "id": "d1-s9",
          "text_original": "她教什么？",
          "pinyin": "Tā jiāo shénme?",
          "text_translation": "U nima dars beradi?",
          "text_translation_ru": "Что она преподаёт?",
