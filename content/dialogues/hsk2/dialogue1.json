          "words": [
            { "i": [0, 1], "p": "wǒ", "t": "men", "tr": "я", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "xiǎng", "t": "xohlamoq", "tr": "хотеть", "h": 1, "l": 5 },
            { "i": [2, 3], "p": "zuò", "t": "bo'lmoq / qilmoq", "tr": "стать", "h": 1, "l": 4 },
            { "i": [3, 5], "p": "lǎoshī", "t": "o'qituvchi", "tr": "учитель", "h": 1, "l": 1 },
            { "i": [6, 8], "p": "yīnwèi", "t": "chunki", "tr": "потому что", "h": 2 },
