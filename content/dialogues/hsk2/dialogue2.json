  "grammarNotes": [
    {
      "pattern": "想 + fe'l",
      "title_uz": "Istakni bildirish: 想",
      "title_ru": "Желание с 想",
      "title_en": "Expressing a wish with 想",
      "desc_uz": "«想» (xiǎng) fe'l oldida kelib, «...moqchi» istagini bildiradi.",
      "desc_ru": "«想» (xiǎng) перед глаголом выражает желание: «хочу...».",
      "desc_en": "«想» (xiǎng) before a verb expresses a wish: \"want to / would like to...\".",
      "ex": "我想吃面条。",
      "expy": "Wǒ xiǎng chī miàntiáo.",
      "ex_uz": "Men lag'mon yegim keladi.",
      "ex_ru": "Я хочу есть лапшу.",
      "ex_en": "I want to eat noodles."
    },
    {
      "pattern": "Son + sanoq so'zi + ot",
      "title_uz": "Sanoq so'zlari: 一杯 / 一碗",
      "title_ru": "Счётные слова: 一杯 / 一碗",
      "title_en": "Measure words: 一杯 / 一碗",
      "desc_uz": "Xitoy tilida ot oldidan sanoq so'zi keladi: 一 + sanoq so'zi + ot. 杯 — piyola/stakan uchun, 碗 — kosa uchun.",
      "desc_ru": "В китайском между числом и существительным ставится счётное слово: 一 + счётн.слово + сущ. 杯 — для чашек/стаканов, 碗 — для мисок.",
      "desc_en": "In Chinese a measure word goes between the number and the noun: 一 + measure word + noun. 杯 is for cups/glasses, 碗 is for bowls.",
      "ex": "一杯茶, 一碗面条",
      "expy": "yì bēi chá, yì wǎn miàntiáo",
      "ex_uz": "bir piyola choy, bir kosa lag'mon",
      "ex_ru": "одна чашка чая, одна миска лапши",
      "ex_en": "a cup of tea, a bowl of noodles"
    },
    {
      "pattern": "...呢？",
      "title_uz": "Qaytariq savol: 你呢？",
      "title_ru": "Возвратный вопрос: 你呢？",
      "title_en": "Echo question with 呢",
      "desc_uz": "Suhbatdoshga xuddi shu savolni qaytarish uchun «你呢？» ishlatiladi: «Senchi?»",
      "desc_ru": "«你呢？» используется, чтобы переадресовать вопрос собеседнику: «А ты?»",
      "desc_en": "«你呢？» bounces the same question back to the listener: \"What about you?\"",
      "ex": "我要茶,你呢？",
      "expy": "Wǒ yào chá, nǐ ne?",
