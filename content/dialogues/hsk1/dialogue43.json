  "grammarNotes": [
    {
      "pattern": "...好了吗？",
      "title_uz": "Ish bajarilganini so'rash",
      "title_ru": "Спросить о завершении действия",
      "desc_uz": "Fe'l + 好了吗 = ... qildingmi? Biror ish tugaganini so'rash uchun.",
      "desc_ru": "Глагол + 好了吗 = ты (уже) сделал? Для вопроса о завершённости действия.",
      "formula": "Fe'l + 好了吗？",
      "formula_ru": "Глагол + 好了吗？",
      "examples": [
        {
          "zh": "安全带系好了吗？",
          "py": "Ānquándài jì hǎo le ma?",
          "uz": "Xavfsizlik kamarini taqdingmi?",
          "ru": "Ремень безопасности пристегнул?",
          "en": "Have you fastened your seatbelt?"
        },
        {
          "zh": "饭做好了吗？",
          "py": "Fàn zuò hǎo le ma?",
          "uz": "Ovqat tayyorlandi mi?",
          "ru": "Еда готова?",
          "en": "Is the food ready?"
        },
        {
          "zh": "作业写好了吗？",
          "py": "Zuòyè xiě hǎo le ma?",
          "uz": "Uy vazifani yozdingmi?",
          "ru": "Домашнее задание написал?",
          "en": "Have you done your homework?"
        }
      ],
      "tip_uz": "好 bu yerda «tayyor / tugallangan» ma'nosida. 做好 = tayyorlab bo'lmoq, 写好 = yozib bo'lmoq.",
      "tip_ru": "好 здесь означает «готово / завершено». 做好 = приготовить, 写好 = дописать.",
      "title_en": "Asking about completion of an action",
      "desc_en": "Verb + 好了吗 = have you (already) done it? Used to ask about the completion of an action.",
      "formula_en": "Verb + 好了吗？",
      "tip_en": "好 here means \"done / completed\". 做好 = to prepare, 写好 = to finish writing."
    },
    {
      "pattern": "...的人呢？",
      "title_uz": "Boshqalar haqida so'rash",
      "title_ru": "Спросить о других",
      "desc_uz": "...的人呢？= ...dagi odamlar-chi? 呢 savol yuklamasi bo'lib, oldingi mavzuga asoslangan savol beradi.",
      "desc_ru": "...的人呢？= а люди ...? 呢 — вопросительная частица, задаёт вопрос на основе предыдущего контекста.",
      "formula": "[Joy/holat] + 的人呢？",
      "formula_ru": "[Место/ситуация] + 的人呢？",
      "examples": [
        {
          "zh": "后面的人呢？",
          "py": "Hòumiàn de rén ne?",
          "uz": "Orqadagilar-chi?",
          "ru": "А люди сзади?",
          "en": "What about the people in the back?"
        },
        {
          "zh": "外面的人呢？",
          "py": "Wàimiàn de rén ne?",
          "uz": "Tashqaridagilar-chi?",
          "ru": "А люди снаружи?",
          "en": "What about the people outside?"
        },
        {
          "zh": "你的朋友呢？",
          "py": "Nǐ de péngyou ne?",
          "uz": "Sening do'sting-chi?",
          "ru": "А твой друг?",
          "en": "What about your friend?"
        }
      ],
      "title_en": "Asking about others",
      "desc_en": "...的人呢？= what about the people who...? 呢 is a question particle that asks based on previous context.",
      "formula_en": "[Place/situation] + 的人呢？"
    },
    {
      "pattern": "也 + Fe'l",
      "title_uz": "Ham / shuningdek",
      "title_ru": "Тоже / также",
      "desc_uz": "也 = ham. Fe'ldan OLDIN keladi. Bir xil harakatning takrorlanishini bildiradi.",
      "desc_ru": "也 = тоже. Ставится ПЕРЕД глаголом. Показывает повторение действия.",
      "formula": "Ega + 也 + Fe'l",
      "formula_ru": "Подлеж. + 也 + Глагол",
      "examples": [
        {
          "zh": "也系好了。",
          "py": "Yě jì hǎo le.",
          "uz": "Ular ham taqishdi.",
          "ru": "Они тоже пристегнулись.",
          "en": "They've fastened theirs too."
        },
        {
          "zh": "我也想去。",
          "py": "Wǒ yě xiǎng qù.",
          "uz": "Men ham bormoqchiman.",
          "ru": "Я тоже хочу пойти.",
          "en": "I also want to go."
        },
        {
          "zh": "他也是学生。",
          "py": "Tā yě shì xuéshēng.",
          "uz": "U ham talaba.",
          "ru": "Он тоже студент.",
          "en": "He's also a student."
        }
      ],
      "tip_uz": "也 har doim fe'ldan OLDIN keladi. \"Men ham\" = 我也, \"U ham\" = 他也.",
      "tip_ru": "也 всегда стоит ПЕРЕД глаголом. «Я тоже» = 我也, «Он тоже» = 他也.",
      "title_en": "Also / too",
      "desc_en": "也 = also/too. Placed BEFORE the verb. Shows repetition of an action.",
      "formula_en": "Subj. + 也 + Verb",
      "tip_en": "也 always comes BEFORE the verb. \"I also\" = 我也, \"He also\" = 他也."
    },
    {
      "pattern": "那我们...吧",
      "title_uz": "Taklif bildirish",
      "title_ru": "Предложить действие",
      "desc_uz": "那 = unda, 吧 = taklif yuklamasi. Birgalikda: «Unda ... qilaylik» ma'nosida.",
      "desc_ru": "那 = тогда, 吧 = частица предложения. Вместе: «Тогда давай...».",
      "formula": "那 + Ega + Fe'l + 吧",
      "formula_ru": "那 + Подлеж. + Глагол + 吧",
      "examples": [
        {
          "zh": "那我们出发吧。",
          "py": "Nà wǒmen chūfā ba.",
          "uz": "Unda jo'naymiz.",
          "ru": "Тогда поехали.",
          "en": "Then let's go."
        },
        {
          "zh": "那我们吃饭吧。",
          "py": "Nà wǒmen chīfàn ba.",
          "uz": "Unda ovqat yeylik.",
          "ru": "Тогда давай поедим.",
          "en": "Then let's eat."
        },
        {
          "zh": "那我们开始吧。",
          "py": "Nà wǒmen kāishǐ ba.",
          "uz": "Unda boshlaymiz.",
          "ru": "Тогда давай начнём.",
          "en": "Then let's start."
        }
      ],
      "title_en": "Suggesting an action",
      "desc_en": "那 = then, 吧 = suggestion particle. Together: \"Then let's...\".",
      "formula_en": "那 + Subj. + Verb + 吧"
    }
  ],
