  "grammarNotes": [
    {
      "pattern": "为什么...？",
      "title_uz": "Sabab so'rash",
      "title_ru": "Спросить причину",
      "desc_uz": "为什么 = nega / nima uchun. Egadan keyin, fe'ldan oldin keladi.",
      "desc_ru": "为什么 = почему. Ставится после подлежащего, перед глаголом.",
      "formula": "Ega + 为什么 + Fe'l？",
      "formula_ru": "Подлеж. + 为什么 + Глагол？",
      "examples": [
        {
          "zh": "你为什么不吃饭？",
          "py": "Nǐ wèi shénme bù chīfàn?",
          "uz": "Nega ovqat yemayapsan?",
          "ru": "Почему ты не ешь?",
          "en": "Why aren't you eating?"
        },
        {
          "zh": "他为什么不来？",
          "py": "Tā wèi shénme bù lái?",
          "uz": "U nega kelmayapti?",
          "ru": "Почему он не приходит?",
          "en": "Why isn't he coming?"
        },
        {
          "zh": "你为什么学中文？",
          "py": "Nǐ wèi shénme xué Zhōngwén?",
          "uz": "Nega xitoy tilini o'rganayapsan?",
          "ru": "Почему ты учишь китайский?",
          "en": "Why are you learning Chinese?"
        }
      ],
      "tip_uz": "为什么 har doim fe'ldan OLDIN keladi. Gap oxiriga qo'ymang!",
      "tip_ru": "为什么 всегда стоит ПЕРЕД глаголом, не в конце предложения!",
      "title_en": "Asking the reason",
      "desc_en": "为什么 = why. Placed after the subject, before the verb.",
      "formula_en": "Subj. + 为什么 + Verb？",
      "tip_en": "为什么 always goes BEFORE the verb, never at the end of the sentence!"
    },
    {
