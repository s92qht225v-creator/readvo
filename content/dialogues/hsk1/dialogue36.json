  "grammarNotes": [
    {
      "pattern": "请问 + 是...吗？",
      "title_uz": "请问是...吗？ — muloyimlik bilan so'rash",
      "title_ru": "请问是...吗？ — вежливо спросить",
      "desc_uz": "\"请问\" (kechirasiz) bilan gap boshlab, \"是...吗？\" bilan savol berish — muloyim so'rov shakli.",
      "desc_ru": "\"请问\" (скажите) в начале + \"是...吗？\" — вежливая форма вопроса.",
      "formula": "请问 + 是 + Ism + 吗？",
      "formula_ru": "请问 + 是 + Имя + 吗？",
      "examples": [
        {
          "zh": "请问是小李吗？",
          "py": "Qǐngwèn shì Xiǎo Lǐ ma?",
          "uz": "Kechirasiz, bu Xiao Limi?",
          "ru": "Скажите, это Сяо Ли?",
          "en": "May I ask, is this Xiao Li?"
        },
        {
          "zh": "请问是王老师吗？",
          "py": "Qǐngwèn shì Wáng lǎoshī ma?",
          "uz": "Kechirasiz, bu Wang o'qituvchimi?",
          "ru": "Скажите, это учитель Ван?",
          "en": "May I ask, is this Teacher Wang?"
        }
      ],
      "tip_uz": "\"请问\" telefon suhbatlarida va notanish odamlardan so'rashda ishlatiladi.",
      "tip_ru": "\"请问\" используется в телефонных разговорах и при обращении к незнакомым людям.",
      "title_en": "请问是...吗？ — asking politely",
      "desc_en": "\"请问\" (may I ask) at the beginning + \"是...吗？\" — a polite way to ask a question.",
      "formula_en": "请问 + 是 + Name + 吗？",
      "tip_en": "\"请问\" is used in phone calls and when addressing strangers."
    },
    {
      "pattern": "Fe'l + 错了",
      "title_uz": "Fe'l + 错了 — noto'g'ri qilmoq",
      "title_ru": "Глагол + 错了 — сделать неправильно",
      "desc_uz": "\"错\" fe'ldan keyin kelib, ish noto'g'ri bajarilganini bildiradi. \"了\" o'tgan zamonni ko'rsatadi.",
      "desc_ru": "\"错\" после глагола показывает, что действие выполнено неправильно. \"了\" указывает на прошедшее время.",
      "formula": "Fe'l + 错 + 了",
      "formula_ru": "Глагол + 错 + 了",
      "examples": [
        {
          "zh": "你打错了。",
          "py": "Nǐ dǎ cuò le.",
          "uz": "Noto'g'ri terdingiz.",
          "ru": "Вы ошиблись номером.",
          "en": "You dialed the wrong number."
        },
        {
          "zh": "我写错了。",
          "py": "Wǒ xiě cuò le.",
          "uz": "Men noto'g'ri yozdim.",
          "ru": "Я написал неправильно.",
          "en": "I wrote it wrong."
        }
      ],
      "tip_uz": "\"打错了\" telefonda eng ko'p ishlatiladigan ibora — noto'g'ri raqam terilganda.",
      "tip_ru": "\"打错了\" — самая частая фраза по телефону, когда набрали неправильный номер.",
      "title_en": "Verb + 错了 — did something wrong",
      "desc_en": "\"错\" after a verb shows the action was done incorrectly. \"了\" indicates past tense.",
      "formula_en": "Verb + 错 + 了",
      "tip_en": "\"打错了\" — the most common phone phrase when you dialed the wrong number."
    },
    {
      "pattern": "不好意思",
      "title_uz": "不好意思 — kechirim so'rash",
      "title_ru": "不好意思 — извиниться",
      "desc_uz": "\"不好意思\" — yengil uzr so'rash uchun ishlatiladi. \"对不起\" dan yengilroq.",
      "desc_ru": "\"不好意思\" — лёгкое извинение. Мягче, чем \"对不起\".",
      "formula": "不好意思 (+ sabab)",
      "formula_ru": "不好意思 (+ причина)",
      "examples": [
        {
          "zh": "不好意思。",
          "py": "Bù hǎoyìsi.",
          "uz": "Uzr so'rayman.",
          "ru": "Извините.",
          "en": "Sorry."
        },
        {
          "zh": "不好意思，我来晚了。",
          "py": "Bù hǎoyìsi, wǒ lái wǎn le.",
          "uz": "Uzr, men kech keldim.",
          "ru": "Извините, я опоздал.",
          "en": "Sorry, I'm late."
        }
      ],
      "tip_uz": "\"不好意思\" — kundalik hayotda eng ko'p ishlatiladigan uzr so'zi. \"对不起\" — jiddiyroq holatlar uchun.",
      "tip_ru": "\"不好意思\" — самое частое извинение в быту. \"对不起\" — для более серьёзных ситуаций.",
      "title_en": "不好意思 — apologizing",
      "desc_en": "\"不好意思\" — a mild apology. Softer than \"对不起\".",
      "formula_en": "不好意思 (+ reason)",
      "tip_en": "\"不好意思\" — the most common casual apology. \"对不起\" — for more serious situations."
    },
    {
      "pattern": "没关系",
      "title_uz": "没关系 — javob: hech gap emas",
      "title_ru": "没关系 — ответ: ничего страшного",
      "desc_uz": "\"没关系\" — uzr so'raganda javob sifatida ishlatiladi. \"Hech gap emas\" degan ma'noni beradi.",
      "desc_ru": "\"没关系\" — ответ на извинение. Означает \"ничего страшного\".",
      "formula": "没关系 (+ qo'shimcha gap)",
      "formula_ru": "没关系 (+ дополнение)",
      "examples": [
