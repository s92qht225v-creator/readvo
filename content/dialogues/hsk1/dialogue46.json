      "sentences": [
        {
          "id": "d46-s1",
          "text_original": "你最近不吃肉吗？",
          "pinyin": "Nǐ zuìjìn bù chī ròu ma?",
          "text_translation": "Sen yaqinda go'sht yemayapsanmi?",
          "text_translation_ru": "Ты в последнее время не ешь мясо?",
          "text_translation_en": "Aren't you eating meat lately?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [1, 3], "p": "zuìjìn", "t": "yaqinda", "tr": "недавно" },
            { "i": [3, 4], "p": "bù", "t": "emas", "tr": "не", "h": 1, "l": 2 },
            { "i": [4, 5], "p": "chī", "t": "yemoq", "tr": "есть", "h": 1, "l": 11 },
            { "i": [5, 6], "p": "ròu", "t": "go'sht", "tr": "мясо" },
            { "i": [6, 7], "p": "ma", "t": "(so'roq)", "tr": "(вопрос)", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d46-s2",
          "text_original": "对。我在减肥。",
          "pinyin": "Duì. Wǒ zài jiǎnféi.",
          "text_translation": "Ha. Men ozayapman.",
          "text_translation_ru": "Да. Я худею.",
          "text_translation_en": "Right. I'm losing weight.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "duì", "t": "to'g'ri", "tr": "правильно", "h": 1, "l": 1 },
            { "i": [2, 3], "p": "wǒ", "t": "men", "tr": "я", "h": 1, "l": 2 },
            { "i": [3, 4], "p": "zài", "t": "(-yapti)", "tr": "(прогрессив)", "h": 1, "l": 7 },
            { "i": [4, 6], "p": "jiǎnféi", "t": "ozmoq", "tr": "худеть" }
          ]
        },
        {
          "id": "d46-s3",
          "text_original": "为什么？你不胖啊！",
          "pinyin": "Wèishénme? Nǐ bú pàng a!",
          "text_translation": "Nega? Sen semiz emassan-ku!",
          "text_translation_ru": "Почему? Ты же не толстый!",
          "text_translation_en": "Why? You're not fat!",
          "speaker": "A",
          "words": [
            { "i": [0, 3], "p": "wèishénme", "t": "nega", "tr": "почему" },
            { "i": [4, 5], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [5, 6], "p": "bú", "t": "emas", "tr": "не", "h": 1, "l": 2 },
            { "i": [6, 7], "p": "pàng", "t": "semiz", "tr": "толстый" },
            { "i": [7, 8], "p": "a", "t": "(ta'kid)", "tr": "(восклицание)" }
          ]
        },
        {
          "id": "d46-s4",
          "text_original": "我想瘦一点。",
          "pinyin": "Wǒ xiǎng shòu yì diǎn.",
          "text_translation": "Men bir oz ozg'inroq bo'lmoqchiman.",
          "text_translation_ru": "Я хочу немного похудеть.",
          "text_translation_en": "I want to be a bit thinner.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "wǒ", "t": "men", "tr": "я", "h": 1, "l": 2 },
            { "i": [1, 2], "p": "xiǎng", "t": "xohlamoq", "tr": "хотеть" },
            { "i": [2, 3], "p": "shòu", "t": "ozg'in", "tr": "худой" },
            { "i": [3, 5], "p": "yì diǎn", "t": "bir oz", "tr": "немного" }
          ]
        },
        {
          "id": "d46-s5",
          "text_original": "你现在吃什么？",
          "pinyin": "Nǐ xiànzài chī shénme?",
          "text_translation": "Hozir nima yeysan?",
          "text_translation_ru": "Что ты сейчас ешь?",
          "text_translation_en": "What do you eat now?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [1, 3], "p": "xiànzài", "t": "hozir", "tr": "сейчас", "h": 1, "l": 5 },
            { "i": [3, 4], "p": "chī", "t": "yemoq", "tr": "есть", "h": 1, "l": 11 },
            { "i": [4, 6], "p": "shénme", "t": "nima", "tr": "что", "h": 1, "l": 3 }
          ]
        },
        {
          "id": "d46-s6",
          "text_original": "吃水果和蔬菜。",
          "pinyin": "Chī shuǐguǒ hé shūcài.",
          "text_translation": "Meva va sabzavot yeyman.",
          "text_translation_ru": "Ем фрукты и овощи.",
          "text_translation_en": "I eat fruit and vegetables.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "chī", "t": "yemoq", "tr": "есть", "h": 1, "l": 11 },
            { "i": [1, 3], "p": "shuǐguǒ", "t": "meva", "tr": "фрукты" },
            { "i": [3, 4], "p": "hé", "t": "va", "tr": "и", "h": 1, "l": 4 },
            { "i": [4, 6], "p": "shūcài", "t": "sabzavot", "tr": "овощи" }
          ]
        },
        {
          "id": "d46-s7",
          "text_original": "你饿吗？",
          "pinyin": "Nǐ è ma?",
          "text_translation": "Qorning ochmi?",
          "text_translation_ru": "Ты голодный?",
          "text_translation_en": "Are you hungry?",
          "speaker": "A",
          "words": [
            { "i": [0, 1], "p": "nǐ", "t": "sen", "tr": "ты", "h": 1, "l": 1 },
            { "i": [1, 2], "p": "è", "t": "och", "tr": "голодный" },
            { "i": [2, 3], "p": "ma", "t": "(so'roq)", "tr": "(вопрос)", "h": 1, "l": 2 }
          ]
        },
        {
          "id": "d46-s8",
          "text_original": "有一点。但是我很开心。",
          "pinyin": "Yǒu yì diǎn. Dànshì wǒ hěn kāixīn.",
          "text_translation": "Bir oz. Lekin men juda xursandman.",
          "text_translation_ru": "Немного. Но я очень счастлив.",
          "text_translation_en": "A little. But I'm very happy.",
          "speaker": "B",
          "words": [
            { "i": [0, 1], "p": "yǒu", "t": "bor", "tr": "есть", "h": 1, "l": 4 },
            { "i": [1, 3], "p": "yì diǎn", "t": "bir oz", "tr": "немного" },
            { "i": [4, 6], "p": "dànshì", "t": "lekin", "tr": "но" },
            { "i": [6, 7], "p": "wǒ", "t": "men", "tr": "я", "h": 1, "l": 2 },
            { "i": [7, 8], "p": "hěn", "t": "juda", "tr": "очень", "h": 1, "l": 6 },
            { "i": [8, 10], "p": "kāixīn", "t": "xursand", "tr": "счастливый" }
          ]
        }
