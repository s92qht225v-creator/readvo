  "grammarNotes": [
    {
      "pattern": "什么时候 + Fe'l？",
      "title_uz": "什么时候 + Fe'l？ — qachonligini so'rash",
      "title_ru": "什么时候 + Глагол？ — спросить «когда»",
      "desc_uz": "\"什么时候\" (qachon) fe'l oldida kelib, ish qachon bo'lishini so'raydi.",
      "desc_ru": "\"什么时候\" (когда) ставится перед глаголом, чтобы спросить о времени действия.",
      "formula": "Sen + 什么时候 + Fe'l？",
      "formula_ru": "Ты + 什么时候 + Глагол？",
      "examples": [
        {
          "zh": "你什么时候走？",
          "py": "Nǐ shénme shíhou zǒu?",
          "uz": "Sen qachon ketasan?",
          "ru": "Когда ты уезжаешь?",
          "en": "When are you leaving?"
        },
        {
          "zh": "你什么时候来？",
          "py": "Nǐ shénme shíhou lái?",
          "uz": "Sen qachon kelasan?",
          "ru": "Когда ты придёшь?",
          "en": "When will you come?"
        }
      ],
      "tip_uz": "Javob sifatida vaqt so'zi ishlatiladi: \"明天\" (ertaga), \"下午\" (tushdan keyin).",
      "tip_ru": "В ответе используется слово времени: \"明天\" (завтра), \"下午\" (после обеда).",
      "title_en": "什么时候 + Verb？ — asking \"when\"",
      "desc_en": "\"什么时候\" (when) is placed before the verb to ask about the time of an action.",
      "formula_en": "You + 什么时候 + Verb？",
      "tip_en": "The answer uses a time word: \"明天\" (tomorrow), \"下午\" (afternoon)."
    },
    {
      "pattern": "A 还是 B？",
      "title_uz": "A 还是 B？ — tanlash savoli",
      "title_ru": "A 还是 B？ — вопрос выбора",
      "desc_uz": "\"还是\" ikki variant orasidan birini tanlash uchun savolda ishlatiladi. \"吗\" qo'shilmaydi.",
      "desc_ru": "\"还是\" используется в вопросе для выбора между двумя вариантами. \"吗\" не добавляется.",
      "formula": "A 还是 B？",
      "formula_ru": "A 还是 B？",
      "examples": [
        {
          "zh": "坐火车还是坐飞机？",
          "py": "Zuò huǒchē háishi zuò fēijī?",
          "uz": "Poezddami yoki samolyotdami?",
          "ru": "На поезде или на самолёте?",
          "en": "By train or by plane?"
        },
        {
          "zh": "你喝茶还是喝水？",
          "py": "Nǐ hē chá háishi hē shuǐ?",
          "uz": "Choy ichasanmi yoki suv?",
          "ru": "Ты будешь чай или воду?",
          "en": "Would you like tea or water?"
        }
      ],
      "tip_uz": "\"还是\" faqat savolda. \"或者\" (yoki) — darak gapda ishlatiladi.",
      "tip_ru": "\"还是\" только в вопросе. \"或者\" (или) — в утвердительном предложении.",
      "title_en": "A 还是 B？ — choice questions",
      "desc_en": "\"还是\" is used in questions to choose between two options. \"吗\" is not added.",
      "formula_en": "A 还是 B？",
      "tip_en": "\"还是\" is only for questions. \"或者\" (or) — in statements."
    },
    {
      "pattern": "坐 + Transport",
      "title_uz": "坐 + Transport — transportda bormoq",
      "title_ru": "坐 + Транспорт — ехать на транспорте",
      "desc_uz": "\"坐\" transport so'zi oldida kelib, \"...da bormoq/minmoq\" ma'nosini beradi.",
      "desc_ru": "\"坐\" перед транспортом означает \"ехать на...\".",
      "formula": "坐 + Transport (+ ketish joyi)",
      "formula_ru": "坐 + Транспорт (+ куда)",
      "examples": [
        {
          "zh": "坐飞机。",
          "py": "Zuò fēijī.",
          "uz": "Samolyotda.",
          "ru": "На самолёте.",
          "en": "By plane."
        },
        {
          "zh": "我坐火车去上海。",
          "py": "Wǒ zuò huǒchē qù Shànghǎi.",
          "uz": "Men poyezdda Shanxayga boraman.",
          "ru": "Я еду в Шанхай на поезде.",
          "en": "I'm going to Shanghai by train."
        }
      ],
      "tip_uz": "\"坐\" so'zma-so'z \"o'tirmoq\" demak, lekin transport bilan \"minmoq\" ma'nosida ishlatiladi.",
      "tip_ru": "\"坐\" буквально означает \"сидеть\", но с транспортом значит \"ехать на\".",
      "title_en": "坐 + transport — taking transport",
      "desc_en": "\"坐\" before a mode of transport means \"to go by...\".",
      "formula_en": "坐 + Transport (+ destination)",
      "tip_en": "\"坐\" literally means \"to sit\", but with transport it means \"to go by\"."
    },
    {
      "pattern": "我送你",
      "title_uz": "我送你 — kuzatib qo'ymoq",
      "title_ru": "我送你 — проводить кого-то",
      "desc_uz": "\"送\" kuzatmoq yoki olib bormoq ma'nosida. \"我送你\" — men seni kuzatib qo'yaman.",
      "desc_ru": "\"送\" значит проводить или отвезти. \"我送你\" — я тебя провожу.",
      "formula": "Men + 送 + Sen",
      "formula_ru": "Я + 送 + Тебя",
      "examples": [
        {
          "zh": "我送你。",
          "py": "Wǒ sòng nǐ.",
          "uz": "Men seni kuzataman.",
          "ru": "Я тебя провожу.",
          "en": "I'll see you off."
        },
        {
          "zh": "他送我到学校。",
          "py": "Tā sòng wǒ dào xuéxiào.",
          "uz": "U meni maktabga olib bordi.",
          "ru": "Он отвёз меня в школу.",
          "en": "He took me to school."
        }
      ],
      "tip_uz": "\"送\" sovg'a berish ma'nosida ham ishlatiladi: \"送你一本书\" — senga kitob sovg'a qilaman.",
      "tip_ru": "\"送\" также значит дарить: \"送你一本书\" — подарю тебе книгу.",
      "title_en": "我送你 — seeing someone off",
      "desc_en": "\"送\" means to see off or give a ride. \"我送你\" — I'll take you / see you off.",
      "formula_en": "I + 送 + You",
      "tip_en": "\"送\" also means to give a gift: \"送你一本书\" — I'll give you a book."
    }
  ],
  "extraVocabSubtitle_en": "Useful words on farewells and seeing off"
}
