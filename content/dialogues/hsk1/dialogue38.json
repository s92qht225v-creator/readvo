  "grammarNotes": [
    {
      "pattern": "最近 + 怎么样？",
      "title_uz": "最近怎么样？ — yaqingi ahvolni so'rash",
      "title_ru": "最近怎么样？ — спросить о последних делах",
      "desc_uz": "\"最近\" (yaqinda) + \"怎么样\" (qanday) bilan suhbatdoshning oxirgi paytlardagi ahvolini so'rashadi.",
      "desc_ru": "\"最近\" (в последнее время) + \"怎么样\" (как дела) — вопрос о том, как дела в последнее время.",
      "formula": "(你) 最近 + 怎么样？",
      "formula_ru": "(Ты) 最近 + 怎么样？",
      "examples": [
        {
          "zh": "你最近怎么样？",
          "py": "Nǐ zuìjìn zěnmeyàng?",
          "uz": "Oxirgi paytlarda qalaysan?",
          "ru": "Как у тебя дела в последнее время?",
          "en": "How have you been lately?"
        },
        {
          "zh": "他最近怎么样？",
          "py": "Tā zuìjìn zěnmeyàng?",
          "uz": "U yaqinda qanday?",
          "ru": "Как у него дела в последнее время?",
          "en": "How has he been lately?"
        }
      ],
      "tip_uz": "Bu savol yaqin do'stlar va tanishlar orasida ishlatiladi. Rasmiy emas.",
      "tip_ru": "Этот вопрос используется между друзьями и знакомыми. Неформальный.",
      "title_en": "最近怎么样？ — asking about recent things",
      "desc_en": "\"最近\" (recently) + \"怎么样\" (how are things) — ask how things have been lately.",
      "formula_en": "(You) 最近 + 怎么样？",
      "tip_en": "This question is used between friends and acquaintances. Informal."
    },
    {
      "pattern": "很 + Sifat",
      "title_uz": "很 + sifat — holat tavsiflash",
      "title_ru": "很 + прилагательное — описание состояния",
      "desc_uz": "\"很\" sifat oldida kelib \"juda\" ma'nosini beradi. Xitoy tilida sifat oldida ko'pincha \"很\" qo'yiladi.",
      "desc_ru": "\"很\" ставится перед прилагательным и означает \"очень\". В китайском перед прилагательным обычно ставят \"很\".",
      "formula": "很 + Sifat",
      "formula_ru": "很 + Прилагательное",
      "examples": [
        {
          "zh": "我最近很忙。",
          "py": "Wǒ zuìjìn hěn máng.",
          "uz": "Men yaqinda juda bandman.",
          "ru": "В последнее время я очень занят.",
          "en": "I've been very busy lately."
        },
        {
          "zh": "她很紧张。",
          "py": "Tā hěn jǐnzhāng.",
          "uz": "U juda hayajonlanyapti.",
          "ru": "Она очень нервничает.",
          "en": "She's very nervous."
        }
      ],
      "tip_uz": "\"很\" ba'zan \"juda\" ma'nosini yo'qotib, oddiygina bog'lovchi vazifasini bajaradi.",
      "tip_ru": "\"很\" иногда теряет значение \"очень\" и просто связывает подлежащее с прилагательным.",
      "title_en": "very + adjective — describing a state",
      "desc_en": "\"很\" is placed before an adjective and means \"very\". In Chinese, \"很\" is usually placed before adjectives.",
      "formula_en": "很 + Adjective",
      "tip_en": "\"很\" sometimes loses the meaning of \"very\" and simply links the subject to the adjective."
    },
    {
      "pattern": "要...了",
      "title_uz": "要...了 — tez orada bo'ladigan hodisa",
      "title_ru": "要...了 — скоро произойдёт",
      "desc_uz": "\"要...了\" biror narsa tez orada bo'lishini bildiradi. Kelajakdagi yaqin hodisa uchun ishlatiladi.",
      "desc_ru": "\"要...了\" указывает, что что-то скоро произойдёт. Используется для ближайших будущих событий.",
      "formula": "(Vaqt +) 要 + Fe'l + 了",
      "formula_ru": "(Время +) 要 + Глагол + 了",
      "examples": [
        {
          "zh": "下个月要考试了。",
          "py": "Xià ge yuè yào kǎoshì le.",
          "uz": "Keyingi oy imtihon bo'ladi.",
          "ru": "В следующем месяце экзамен.",
          "en": "The exam is next month."
        },
        {
          "zh": "要下雨了。",
          "py": "Yào xià yǔ le.",
          "uz": "Yomg'ir yog'moqchi.",
          "ru": "Скоро пойдёт дождь.",
          "en": "It's going to rain soon."
        }
      ],
      "tip_uz": "\"要...了\" = tez orada. \"快要...了\" ham xuddi shu ma'noda ishlatiladi, lekin yanada tezroqni anglatadi.",
      "tip_ru": "\"要...了\" = скоро. \"快要...了\" — то же значение, но подчёркивает, что совсем скоро.",
      "title_en": "要...了 — about to happen",
      "desc_en": "\"要...了\" indicates something is about to happen. Used for events in the near future.",
      "formula_en": "(Time +) 要 + Verb + 了",
      "tip_en": "\"要...了\" = soon. \"快要...了\" — same meaning but emphasizes it's very soon."
    },
    {
      "pattern": "Sifat + 吗？",
