  "grammarNotes": [
    {
      "pattern": "Fe'l + 完",
      "title_uz": "Fe'l + 完 — ishni tugatish",
      "title_ru": "Глагол + 完 — завершение действия",
      "desc_uz": "\"完\" fe'ldan keyin kelib, ish tugaganini bildiradi. Bu natija to'ldiruvchisi (result complement) hisoblanadi.",
      "desc_ru": "\"完\" ставится после глагола и показывает, что действие завершено. Это результативное дополнение.",
      "formula": "Fe'l + 完 (+ 了)",
      "formula_ru": "Глагол + 完 (+ 了)",
      "examples": [
        {
          "zh": "作业写完了。",
          "py": "Zuòyè xiě wán le.",
          "uz": "Uy vazifa yozib bo'ldi.",
          "ru": "Домашнее задание дописано.",
          "en": "The homework is finished."
        },
        {
          "zh": "书看完了吗？",
          "py": "Shū kàn wán le ma?",
          "uz": "Kitobni o'qib bo'ldingmi?",
          "ru": "Книгу дочитал?",
          "en": "Have you finished reading the book?"
        }
      ],
      "tip_uz": "\"完\" faqat tugashi mumkin bo'lgan ishlar bilan ishlatiladi: yozmoq, o'qimoq, yemoq va h.k.",
      "tip_ru": "\"完\" используется только с действиями, которые можно завершить: писать, читать, есть и т.д.",
      "title_en": "Verb + 完 — completing an action",
      "desc_en": "\"完\" is placed after a verb and shows the action is completed. This is a resultative complement.",
      "formula_en": "Verb + 完 (+ 了)",
      "tip_en": "\"完\" is only used with actions that can be completed: write, read, eat, etc."
    },
    {
      "pattern": "还没 + Fe'l",
      "title_uz": "还没 + Fe'l — hali qilmadim",
      "title_ru": "还没 + Глагол — ещё не сделал",
      "desc_uz": "\"还没\" hali biror narsa qilinmaganini bildiradi. Ish kutilmoqda, lekin hali tugamagan.",
      "desc_ru": "\"还没\" указывает, что действие ещё не выполнено. Ожидается, но пока не завершено.",
      "formula": "还没 + Fe'l (+ 完)",
      "formula_ru": "还没 + Глагол (+ 完)",
      "examples": [
        {
          "zh": "还没写完。",
          "py": "Hái méi xiě wán.",
          "uz": "Hali yozib bo'lmadim.",
          "ru": "Ещё не дописал.",
          "en": "Haven't finished writing yet."
        },
        {
          "zh": "他还没来。",
          "py": "Tā hái méi lái.",
          "uz": "U hali kelmadi.",
          "ru": "Он ещё не пришёл.",
          "en": "He hasn't come yet."
        }
      ],
      "tip_uz": "\"还没\" — inkor shakl. \"已经...了\" — tasdiqlash shakl: \"已经写完了\" (allaqachon yozib bo'ldi).",
      "tip_ru": "\"还没\" — отрицание. Утверждение: \"已经...了\" — \"已经写完了\" (уже дописал).",
      "title_en": "还没 + Verb — haven't done yet",
      "desc_en": "\"还没\" indicates an action hasn't been done yet. It's expected but not yet completed.",
      "formula_en": "还没 + Verb (+ 完)",
      "tip_en": "\"还没\" — negation. Affirmative: \"已经...了\" — \"已经写完了\" (already finished writing)."
    },
    {
      "pattern": "还差 + Miqdor",
      "title_uz": "还差 + Miqdor — yana qancha qoldi",
      "title_ru": "还差 + Количество — сколько ещё осталось",
      "desc_uz": "\"还差\" biror narsaning yetishmasligini yoki qolganini bildiradi. Undan keyin miqdor keladi.",
      "desc_ru": "\"还差\" показывает нехватку или оставшееся количество. После него идёт количество.",
      "formula": "还差 + Miqdor / 多少",
      "formula_ru": "还差 + Количество / 多少",
      "examples": [
        {
          "zh": "还差多少？",
          "py": "Hái chà duōshao?",
          "uz": "Yana qancha qoldi?",
          "ru": "Сколько ещё осталось?",
          "en": "How much is left?"
        },
        {
          "zh": "还差一半。",
          "py": "Hái chà yíbàn.",
          "uz": "Yana yarmi qoldi.",
          "ru": "Ещё половина.",
          "en": "Still half left."
        }
      ],
      "tip_uz": "\"还差\" vaqt uchun ham ishlatiladi: \"还差五分钟\" (yana 5 daqiqa qoldi).",
      "tip_ru": "\"还差\" также используется для времени: \"还差五分钟\" (ещё 5 минут осталось).",
      "title_en": "还差 + amount — how much is still needed",
      "desc_en": "\"还差\" shows a shortage or remaining amount. The quantity follows after it.",
      "formula_en": "还差 + Amount / 多少",
      "tip_en": "\"还差\" is also used for time: \"还差五分钟\" (5 minutes left)."
    },
    {
      "pattern": "能 + Fe'l + 吗？",
      "title_uz": "能...吗？ — qobiliyatni so'rash",
      "title_ru": "能...吗？ — спросить о возможности",
      "desc_uz": "\"能\" biror ishni qila olish qobiliyatini bildiradi. \"吗\" bilan savol tuziladi.",
      "desc_ru": "\"能\" выражает способность или возможность что-то сделать. С \"吗\" образует вопрос.",
      "formula": "能 + Fe'l (+ Natija) + 吗？",
      "formula_ru": "能 + Глагол (+ Результат) + 吗？",
      "examples": [
        {
          "zh": "今天能写完吗？",
          "py": "Jīntiān néng xiě wán ma?",
          "uz": "Bugun yozib tugata olasanmi?",
          "ru": "Сегодня сможешь дописать?",
          "en": "Can you finish writing today?"
        },
        {
          "zh": "你能来吗？",
          "py": "Nǐ néng lái ma?",
          "uz": "Kela olasanmi?",
          "ru": "Ты сможешь прийти?",
          "en": "Can you come?"
        }
      ],
      "tip_uz": "\"能\" qisqa javob uchun ham ishlatiladi: \"能。\" (olaman) yoki \"不能。\" (ololmayman).",
      "tip_ru": "\"能\" можно использовать как краткий ответ: \"能。\" (смогу) или \"不能。\" (не смогу).",
      "title_en": "能...吗？ — asking about possibility",
      "desc_en": "\"能\" expresses the ability or possibility to do something. With \"吗\" it forms a question.",
      "formula_en": "能 + Verb (+ Result) + 吗？",
      "tip_en": "\"能\" can be used as a short answer: \"能\" (I can) or \"不能\" (I can't)."
    }
  ],
  "extraVocabSubtitle_en": "Useful words on school and homework"
}
