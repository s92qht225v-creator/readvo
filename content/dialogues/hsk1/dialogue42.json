  "grammarNotes": [
    {
      "pattern": "...到了",
      "title_uz": "到了 — yetib keldi (tugallangan harakat)",
      "title_ru": "到了 — прибыл (завершённое действие)",
      "desc_uz": "\"到\" fe'li \"了\" bilan birgalikda ishlatilganda, biror narsa yoki kishi manzilga yetib kelganini bildiradi.",
      "desc_ru": "Глагол \"到\" с частицей \"了\" указывает на завершённое прибытие — что-то или кто-то уже на месте.",
      "formula": "Ot + 到了",
      "formula_ru": "Сущ. + 到了",
      "examples": [
        {
          "zh": "外卖到了。",
          "py": "Wàimài dào le.",
          "uz": "Dostavka yetib keldi.",
          "ru": "Доставка приехала.",
          "en": "The delivery has arrived."
        },
        {
          "zh": "他到了吗？",
          "py": "Tā dào le ma?",
          "uz": "U yetib keldimi?",
          "ru": "Он приехал?",
          "en": "Has he arrived?"
        },
        {
          "zh": "快递到了。",
          "py": "Kuàidì dào le.",
          "uz": "Pochta yetib keldi.",
          "ru": "Посылка пришла.",
          "en": "The package has arrived."
        }
      ],
      "tip_uz": "\"到了\" ko'pincha yetkazib berish, transport yoki odamlar haqida ishlatiladi.",
      "tip_ru": "\"到了\" часто используется для доставки, транспорта или прибытия людей.",
      "title_en": "到了 — arrived (completed action)",
      "desc_en": "The verb \"到\" with the particle \"了\" indicates a completed arrival — something or someone has already arrived.",
      "formula_en": "Noun + 到了",
      "tip_en": "\"到了\" is often used for deliveries, transport, or people arriving."
    },
