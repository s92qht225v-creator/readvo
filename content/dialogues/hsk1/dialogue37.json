  "grammarNotes": [
    {
      "pattern": "...到了吗？",
      "title_uz": "...到了吗？ — yetib kelganini so'rash",
      "title_ru": "...到了吗？ — спросить о прибытии",
      "desc_uz": "\"到\" (yetib kelmoq) + \"了\" (o'tgan zamon) + \"吗\" (savol) — biror kishi yetib kelganini so'rash uchun ishlatiladi.",
      "desc_ru": "\"到\" (прибыть) + \"了\" (прош. время) + \"吗\" (вопрос) — спросить, прибыл ли кто-то.",
      "formula": "(Sen) + 到了吗？",
      "formula_ru": "(Ты) + 到了吗？",
      "examples": [
        { "zh": "你到了吗？", "py": "Nǐ dào le ma?", "uz": "Yetib keldingmi?", "ru": "Ты приехал?" },
        { "zh": "他到了吗？", "py": "Tā dào le ma?", "uz": "U yetib keldimi?", "ru": "Он приехал?" }
      ],
      "tip_uz": "Javob: \"到了。\" (keldim) yoki \"还没到。\" (hali kelmayman).",
      "tip_ru": "Ответ: \"到了。\" (приехал) или \"还没到。\" (ещё нет)."
    },
    {
      "pattern": "在 + Joy",
      "title_uz": "在 + joy — joyni bildirish",
      "title_ru": "在 + место — указание места",
      "desc_uz": "\"在\" joy-makon so'zi oldida kelib, biror narsa yoki kishining qayerda ekanini bildiradi.",
      "desc_ru": "\"在\" перед словом места указывает, где находится кто-то или что-то.",
      "formula": "在 + Joy (+ so'z)",
      "formula_ru": "在 + Место",
      "examples": [
        { "zh": "在门口。", "py": "Zài ménkǒu.", "uz": "Eshik oldida.", "ru": "У входа." },
        { "zh": "我在学校。", "py": "Wǒ zài xuéxiào.", "uz": "Men maktabdaman.", "ru": "Я в школе." }
      ],
      "tip_uz": "\"在哪儿？\" — qayerda? deb so'rash uchun ishlatiladi.",
      "tip_ru": "\"在哪儿？\" — используется, чтобы спросить \"где?\"."
    },
    {
      "pattern": "Fe'l + 一下",
      "title_uz": "Fe'l + 一下 — biroz qilmoq",
      "title_ru": "Глагол + 一下 — сделать немного",
      "desc_uz": "\"一下\" fe'ldan keyin kelib, ishni biroz, qisqa vaqt qilishni bildiradi. Iltimosni yumshatadi.",
      "desc_ru": "\"一下\" после глагола означает сделать что-то ненадолго, чуть-чуть. Смягчает просьбу.",
      "formula": "Fe'l + 一下",
      "formula_ru": "Глагол + 一下",
      "examples": [
        { "zh": "等我一下。", "py": "Děng wǒ yíxià.", "uz": "Meni biroz kutib tur.", "ru": "Подожди меня." },
        { "zh": "看一下。", "py": "Kàn yíxià.", "uz": "Bir ko'ring.", "ru": "Посмотри-ка." }
      ],
      "tip_uz": "\"一下\" iltimosni yumshatadi. \"等我\" = kutib tur! \"等我一下\" = biroz kutib tur (yumshoq).",
      "tip_ru": "\"一下\" смягчает просьбу. \"等我\" = жди! \"等我一下\" = подожди немного (мягче)."
    },
    {
      "pattern": "好。",
      "title_uz": "好 — rozi bo'lish",
      "title_ru": "好 — согласие",
      "desc_uz": "\"好\" javob sifatida \"xo'p\", \"bo'pti\", \"rozi\" ma'nosini beradi. Iltimos yoki taklifga rozilik bildiradi.",
      "desc_ru": "\"好\" в ответе означает \"хорошо\", \"ладно\", \"согласен\". Выражает согласие на просьбу или предложение.",
      "formula": "好 / 好的",
