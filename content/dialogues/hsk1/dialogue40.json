  "grammarNotes": [
    {
      "pattern": "来 + Miqdor + Ot",
      "title_uz": "来 — restoranda buyurtma berish",
      "title_ru": "来 — заказ в ресторане",
      "desc_uz": "\"来\" restoranda buyurtma berishda \"olib keling\" ma'nosida ishlatiladi. Undan keyin miqdor so'zi va taom nomi keladi.",
      "desc_ru": "\"来\" используется при заказе в ресторане в значении \"принесите\". После него идёт счётное слово и название блюда.",
      "formula": "来 + Miqdor + Ot",
      "formula_ru": "来 + Счётное слово + Сущ.",
      "examples": [
        {
          "zh": "来一份大盘鸡。",
          "py": "Lái yí fèn dàpánjī.",
          "uz": "Bir porsiya dapanji olib keling.",
          "ru": "Одну порцию дапаньцзи.",
          "en": "One serving of dapanji."
        },
        {
          "zh": "来两杯咖啡。",
          "py": "Lái liǎng bēi kāfēi.",
          "uz": "Ikki piyola qahva olib keling.",
          "ru": "Два кофе, пожалуйста.",
          "en": "Two coffees, please."
        },
        {
          "zh": "来一碗面条。",
          "py": "Lái yì wǎn miàntiáo.",
          "uz": "Bir kosa lag'mon olib keling.",
          "ru": "Одну тарелку лапши.",
          "en": "One bowl of noodles."
        }
      ],
      "tip_uz": "\"来\" — norasmiy buyurtma usuli. Rasmiyroq: \"请给我...\" (menga bering).",
      "tip_ru": "\"来\" — неформальный способ заказа. Формальнее: \"请给我...\" (дайте мне).",
      "title_en": "来 — ordering in a restaurant",
      "desc_en": "\"来\" is used when ordering in a restaurant, meaning \"bring me\". It's followed by a measure word and the dish name.",
      "formula_en": "来 + Measure word + Noun",
      "tip_en": "\"来\" — an informal way to order. More formal: \"请给我...\" (please give me)."
    },
    {
      "pattern": "能...吗？",
      "title_uz": "能...吗？ — qobiliyatni so'rash",
      "title_ru": "能...吗？ — спросить о способности",
      "desc_uz": "\"能\" biror narsa qila olish qobiliyatini bildiradi. \"吗\" bilan savol tuziladi.",
      "desc_ru": "\"能\" обозначает способность или возможность что-то сделать. С \"吗\" образует вопрос.",
      "formula": "Ot + 能 + Fe'l + 吗？",
      "formula_ru": "Сущ. + 能 + Глагол + 吗？",
      "examples": [
        {
          "zh": "你能吃辣吗？",
          "py": "Nǐ néng chī là ma?",
          "uz": "Achchiq yeya olasanmi?",
          "ru": "Ты можешь есть острое?",
          "en": "Can you eat spicy food?"
        },
        {
          "zh": "你能来吗？",
          "py": "Nǐ néng lái ma?",
          "uz": "Kela olasanmi?",
          "ru": "Ты сможешь прийти?",
          "en": "Can you come?"
        },
        {
          "zh": "他能喝酒吗？",
          "py": "Tā néng hē jiǔ ma?",
          "uz": "U spirtli ichimlik icha oladimi?",
          "ru": "Он может пить алкоголь?",
          "en": "Can he drink alcohol?"
        }
      ],
      "tip_uz": "\"能\" — jismoniy qobiliyat. \"可以\" — ruxsat. Farqi muhim!",
      "tip_ru": "\"能\" — физическая способность. \"可以\" — разрешение. Разница важна!",
      "title_en": "能...吗？ — asking about ability",
      "desc_en": "\"能\" indicates the ability or possibility to do something. With \"吗\" it forms a question.",
      "formula_en": "Noun + 能 + Verb + 吗？",
      "tip_en": "\"能\" — physical ability. \"可以\" — permission. The difference matters!"
    },
    {
      "pattern": "很 + Sifat",
      "title_uz": "很 + sifat — ta'mni/xususiyatni tavsiflash",
      "title_ru": "很 + прилагательное — описание вкуса/свойства",
      "desc_uz": "\"很\" sifat oldida kelib \"juda\" ma'nosini beradi. Xitoy tilida sifat oldida ko'pincha \"很\" qo'yiladi.",
      "desc_ru": "\"很\" перед прилагательным означает \"очень\". В китайском языке \"很\" часто ставится перед прилагательными.",
      "formula": "Ot + 很 + Sifat",
      "formula_ru": "Сущ. + 很 + Прил.",
      "examples": [
        {
          "zh": "大盘鸡很辣。",
          "py": "Dàpánjī hěn là.",
          "uz": "Dapanji juda achchiq.",
          "ru": "Дапаньцзи очень острое.",
          "en": "Dapanji is very spicy."
        },
        {
          "zh": "今天很冷。",
          "py": "Jīntiān hěn lěng.",
          "uz": "Bugun juda sovuq.",
          "ru": "Сегодня очень холодно.",
          "en": "It's very cold today."
        },
        {
          "zh": "这个菜很好吃。",
          "py": "Zhège cài hěn hǎochī.",
          "uz": "Bu taom juda mazali.",
          "ru": "Это блюдо очень вкусное.",
          "en": "This dish is very delicious."
        }
      ],
      "tip_uz": "Xitoy tilida \"很\" ko'pincha \"juda\" emas, oddiy ta'rif sifatida ishlatiladi.",
      "tip_ru": "В китайском \"很\" часто используется не как \"очень\", а просто как связка перед прилагательным.",
      "title_en": "很 + adjective — describing taste/properties",
      "desc_en": "\"很\" before an adjective means \"very\". In Chinese, \"很\" is often placed before adjectives.",
      "formula_en": "Noun + 很 + Adj.",
      "tip_en": "In Chinese, \"很\" is often used not as \"very\" but simply as a link before adjectives."
    },
    {
      "pattern": "再来...",
