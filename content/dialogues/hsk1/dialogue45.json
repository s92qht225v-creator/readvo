  "grammarNotes": [
    {
      "pattern": "怎么...？",
      "title_uz": "Sabab so'rash (hayron qolish)",
      "title_ru": "Спросить причину (удивление)",
      "desc_uz": "怎么 = nega / qanday qilib. Biror narsaga hayron qolganda ishlatiladi.",
      "desc_ru": "怎么 = почему / как так. Используется, когда удивляешься чему-то.",
      "formula": "Ega + 怎么 + Fe'l？",
      "formula_ru": "Подлеж. + 怎么 + Глагол？",
      "examples": [
        {
          "zh": "你怎么不接电话？",
          "py": "Nǐ zěnme bù jiē diànhuà?",
          "uz": "Nega telefonga javob bermading?",
          "ru": "Почему ты не отвечал на звонок?",
          "en": "Why didn't you answer the phone?"
        },
        {
          "zh": "你怎么不吃饭？",
          "py": "Nǐ zěnme bù chīfàn?",
          "uz": "Nega ovqat yemayapsan?",
          "ru": "Почему ты не ешь?",
          "en": "Why aren't you eating?"
        },
        {
          "zh": "你怎么来了？",
          "py": "Nǐ zěnme lái le?",
          "uz": "Qanday qilib kelding?",
          "ru": "Как ты пришёл?",
          "en": "How did you get here?"
        }
      ],
      "tip_uz": "怎么 hayronlik bildirganda fe'ldan OLDIN keladi. Oddiy savol uchun 为什么 ishlating.",
      "tip_ru": "怎么 в значении удивления стоит ПЕРЕД глаголом. Для обычного вопроса используйте 为什么.",
      "title_en": "Asking the reason (surprise)",
      "desc_en": "怎么 = why / how come. Used when you're surprised about something.",
      "formula_en": "Subj. + 怎么 + Verb？",
      "tip_en": "怎么 (expressing surprise) goes BEFORE the verb. For a regular question, use 为什么."
    },
