    {
      "id": "u1p1-sec-grammar3",
      "type": "grammar",
      "heading": "",
      "subheading": "Stative verbs",
      "subheading_ru": "Stative verbs",
      "sentences": [],
      "tip": {
        "label": "Form",
        "label_uz": "Shakli",
        "label_ru": "Форма",
        "text": "",
        "translation": "Stative verbs odatda harakatlarni emas, holatlarni (his-tuyg'ular, fikrlar va h.k.) ifodalaydi. Ular odatda davomiy zamonlarda ishlatilmaydi.\n\n✓ I **like** reading books in my free time.\n✗ _I **am liking** reading books in my free time._\n\nSome common stative verbs:",
        "translation_ru": "Stative verbs обычно не описывают действия. Они описывают состояния (чувства, мысли и т.д.). Они обычно не используются в продолжительных временах.\n\n✓ I **like** reading books in my free time.\n✗ _I **am liking** reading books in my free time._\n\nSome common stative verbs:",
        "vocabList": [
          { "en": "appear", "uz": "ko'rinmoq", "ru": "казаться" },
          { "en": "be", "uz": "bo'lmoq", "ru": "быть" },
          { "en": "believe", "uz": "ishonmoq", "ru": "верить" },
          { "en": "belong to", "uz": "tegishli bo'lmoq", "ru": "принадлежать" },
          { "en": "hate", "uz": "yomon ko'rmoq", "ru": "ненавидеть" },
          { "en": "have", "uz": "ega bo'lmoq", "ru": "иметь" },
          { "en": "include", "uz": "o'z ichiga olmoq", "ru": "включать" },
          { "en": "know", "uz": "bilmoq", "ru": "знать" },
          { "en": "like", "uz": "yoqtirmoq", "ru": "нравиться" },
          { "en": "love", "uz": "sevmoq", "ru": "любить" },
          { "en": "need", "uz": "kerak bo'lmoq", "ru": "нуждаться" },
          { "en": "prefer", "uz": "afzal ko'rmoq", "ru": "предпочитать" },
          { "en": "see", "uz": "ko'rmoq", "ru": "видеть" },
          { "en": "seem", "uz": "tuyulmoq", "ru": "казаться" },
          { "en": "taste", "uz": "ta'mi bo'lmoq", "ru": "иметь вкус" },
          { "en": "think", "uz": "o'ylamoq", "ru": "думать" },
          { "en": "understand", "uz": "tushunmoq", "ru": "понимать" },
          { "en": "want", "uz": "xohlamoq", "ru": "хотеть" }
        ]
      }
    },
